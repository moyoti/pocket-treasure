{
  "expo": {
    "name": "寻宝记",
    "slug": "treasure-hunt",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "treasurehunt",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFF8E7"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.treasurehunt.app",
      "buildNumber": "1.0.0",
      "infoPlist": {
        "CFBundleDisplayName": "Treasure Hunt",
        "NSLocationWhenInUseUsageDescription": "Allow Treasure Hunt to use your location to show nearby treasures.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Allow Treasure Hunt to use your location to detect nearby treasures.",
        "NSLocationAlwaysUsageDescription": "Allow Treasure Hunt to use your location to detect nearby treasures.",
        "UIUserInterfaceStyle": "Light"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFF8E7"
      },
      "package": "com.treasurehunt.app",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Treasure Hunt to use your location to detect nearby treasures."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "treasure-hunt-mobile"
      }
    }
  }
}