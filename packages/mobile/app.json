{
  "expo": {
    "name": "Treasure Cat",
    "slug": "treasure-cat",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "treasurecat",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFF8E7"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.treasurecat.app",
      "buildNumber": "1",
      "infoPlist": {
        "CFBundleDisplayName": "宝探し猫",
        "NSLocationWhenInUseUsageDescription": "近くの宝を表示するには位置情報が必要です。",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "近くの宝を検出するには位置情報が必要です。",
        "NSLocationAlwaysUsageDescription": "近くの宝を検出するには位置情報が必要です。",
        "UIUserInterfaceStyle": "Light"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFF8E7"
      },
      "package": "com.treasurecat.app",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "INTERNET"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "近くの宝を検出するには位置情報が必要です。"
        }
      ],
      "expo-sqlite",
      [
        "@rnmapbox/maps",
        {
          "accessToken": "pk.eyJ1IjoiYm91c2gxMTExMSIsImEiOiJjbW5scjhuOHMxZWRwMnJxNHJuYTl0MnZwIn0.VLL5LCZt91GK8ZAOr96cnA"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "treasure-hunt-mobile"
      }
    }
  }
}
