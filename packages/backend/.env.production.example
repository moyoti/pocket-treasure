# ============================================
# PRODUCTION ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env and fill in the values
# NEVER commit .env to version control!
# ============================================

# ============================================
# DATABASE (Railway PostgreSQL)
# ============================================
# Get these from your Railway PostgreSQL connection string
# Format: postgresql://username:password@host:port/database
DB_TYPE=postgres
DB_HOST=containers.YOUR-RAILWAY-PROJECT.railway.app
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=YOUR-RAILWAY-PASSWORD
DB_DATABASE=treasure_hunt

# ============================================
# JWT AUTHENTICATION
# ============================================
# Generate a secure random string (64+ characters)
# Example: openssl rand -hex 32
JWT_SECRET=YOUR-SECURE-RANDOM-64-CHAR-STRING
JWT_EXPIRES_IN=7d

# ============================================
# MAPBOX (Maps)
# ============================================
# Get from: https://account.mapbox.com/access-tokens/
MAPBOX_ACCESS_TOKEN=pk.eyJ1Ijoid....

# ============================================
# GOOGLE OAUTH (Required for App Store)
# ============================================
# Get from: https://console.cloud.google.com/
# 1. Create OAuth Client ID (Web application)
# 2. Add authorized origins: https://yourdomain.com, http://localhost:3000
GOOGLE_CLIENT_ID=YOUR-GOOGLE-CLIENT-ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=YOUR-GOOGLE-CLIENT-SECRET

# ============================================
# APPLE OAUTH (Required for App Store)
# ============================================
# Get from: https://developer.apple.com/
# 1. Enroll in Apple Developer Program ($99/year)
# 2. Create App ID with Sign in with Apple enabled
# 3. Create Services ID and OAuth Key
APPLE_CLIENT_ID=com.yourcompany.treasurehunt
APPLE_TEAM_ID=XXXXXXXXXX  # Found in Apple Developer Membership
APPLE_KEY_ID=XXXXXXXXXX  # From your OAuth Key
APPLE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nYOUR\nPRIVATE\nKEY\nHERE\n-----END PRIVATE KEY-----

# ============================================
# WECHAT MINIPROGRAM (Optional - China only)
# ============================================
# Get from: https://developers.weixin.qq.com/
WECHAT_APPID=YOUR-WECHAT-APPID
WECHAT_SECRET=YOUR-WECHAT-SECRET

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=3000
NODE_ENV=production
