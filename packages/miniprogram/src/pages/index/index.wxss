.container {
  min-height: 100vh;
  padding: 80rpx 40rpx 40rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

.hero-section {
  text-align: center;
  padding: 40rpx 0;
}

.logo-wrapper {
  position: relative;
  display: inline-block;
}

.logo-icon {
  width: 180rpx;
  height: 180rpx;
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 100rpx;
  margin: 0 auto;
  border: 8rpx solid var(--border-color);
  box-shadow: 0 12rpx 0 rgba(0, 0, 0, 0.1);
  animation: float 3s ease-in-out infinite;
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-20rpx); }
}

.logo-icon-small {
  position: absolute;
  width: 90rpx;
  height: 90rpx;
  background: linear-gradient(135deg, #FCD34D 0%, #F59E0B 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 50rpx;
  right: -20rpx;
  bottom: 80rpx;
  border: 6rpx solid var(--border-color);
  box-shadow: 0 6rpx 0 rgba(0, 0, 0, 0.1);
}

.title {
  font-size: 72rpx;
  font-weight: 900;
  color: var(--text-primary);
  margin-top: 40rpx;
  text-shadow: 4rpx 4rpx 0 var(--primary-color), 6rpx 6rpx 0 rgba(0,0,0,0.1);
}

.subtitle {
  font-size: 32rpx;
  color: var(--text-secondary);
  margin-top: 16rpx;
}

.slogan {
  font-size: 28rpx;
  color: var(--text-muted);
  margin-top: 12rpx;
  font-weight: 500;
}

.features-section {
  margin-top: 60rpx;
  padding: 30rpx;
  background: white;
  border-radius: 30rpx;
  border: 6rpx solid var(--border-color);
  box-shadow: 0 8rpx 0 rgba(0, 0, 0, 0.1);
}

.feature-item {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 24rpx 0;
  border-bottom: 4rpx solid #F3F4F6;
}

.feature-item:last-child {
  border-bottom: none;
}

.feature-icon {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #FEF3C7 0%, #FCD34D 100%);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  border: 4rpx solid var(--border-color);
}

.feature-info {
  flex: 1;
}

.feature-title {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--text-primary);
}

.feature-desc {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-top: 6rpx;
}

.action-section {
  margin-top: auto;
  padding: 40rpx 0;
}

.primary-btn {
  width: 100%;
  margin-bottom: 20rpx;
  font-size: 34rpx;
  padding: 30rpx;
}

.secondary-btn {
  width: 100%;
  background: white;
  font-size: 30rpx;
  padding: 24rpx;
}

.footer {
  text-align: center;
  padding: 20rpx;
}

.footer-text {
  font-size: 24rpx;
  color: var(--text-muted);
}
