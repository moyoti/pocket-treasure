/* ===== Icon sizes ===== */
.icon {
  width: 36rpx;
  height: 36rpx;
  vertical-align: middle;
}
.icon-sm {
  width: 28rpx;
  height: 28rpx;
  vertical-align: middle;
}
.icon-lg {
  width: 48rpx;
  height: 48rpx;
  vertical-align: middle;
}
.icon-xl {
  width: 64rpx;
  height: 64rpx;
  vertical-align: middle;
}

.container {
  min-height: 100vh;
  padding: 80rpx 40rpx 40rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* ===== Hero区域 ===== */
.hero-section {
  text-align: center;
  padding: 20rpx 0 40rpx;
}

.logo-wrapper {
  position: relative;
  display: inline-block;
  margin-bottom: 20rpx;
}

.logo-main {
  width: 180rpx;
  height: 180rpx;
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 100rpx;
  margin: 0 auto;
  border: 8rpx solid var(--border-color);
  box-shadow: 0 12rpx 0 rgba(0, 0, 0, 0.1);
}

.logo-sub {
  position: absolute;
  right: -24rpx;
  bottom: -12rpx;
  width: 90rpx;
  height: 90rpx;
  background: linear-gradient(135deg, #FCD34D 0%, #F59E0B 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 50rpx;
  border: 6rpx solid var(--border-color);
  box-shadow: 0 6rpx 0 rgba(0, 0, 0, 0.1);
}

.hero-title {
  font-size: 76rpx;
  font-weight: 900;
  color: var(--text-primary);
  margin-top: 30rpx;
  text-shadow: 4rpx 4rpx 0 var(--primary-color), 8rpx 8rpx 0 rgba(0, 0, 0, 0.08);
}

.hero-subtitle {
  font-size: 32rpx;
  color: var(--text-secondary);
  margin-top: 12rpx;
  font-weight: 600;
}

.hero-slogan {
  font-size: 26rpx;
  color: var(--text-muted);
  margin-top: 10rpx;
}

/* ===== 特色卡片 ===== */
.features-grid {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 40rpx;
}

.feature-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 30rpx;
  border-radius: 24rpx;
  border: 6rpx solid var(--border-color);
  box-shadow: 0 6rpx 0 rgba(0, 0, 0, 0.08);
  transition: all 0.2s;
}

.feature-card-hover {
  transform: translateY(-4rpx) scale(1.01);
  box-shadow: 0 12rpx 0 rgba(0, 0, 0, 0.1);
}

.feature-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.7);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid rgba(0, 0, 0, 0.1);
  flex-shrink: 0;
}

.feature-icon {
  width: 44rpx;
  height: 44rpx;
}

.feature-content {
  flex: 1;
}

.feature-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-primary);
  display: block;
}

.feature-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 6rpx;
  display: block;
}

/* ===== CTA按钮 ===== */
.cta-section {
  width: 100%;
  margin-top: auto;
  padding: 50rpx 0 0;
}

.cta-primary {
  width: 100%;
  font-size: 34rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
}

.cta-secondary {
  width: 100%;
  background: white;
  font-size: 30rpx;
  font-weight: bold;
  padding: 26rpx;
  border-radius: 50rpx;
  border: 6rpx solid var(--border-color);
  color: var(--text-primary);
  text-align: center;
}

.cta-secondary-hover {
  background: #F9FAFB;
  transform: scale(0.98);
}

/* ===== 底部提示 ===== */
.footer-hint {
  text-align: center;
  padding: 30rpx 0 20rpx;
}

.footer-text {
  font-size: 24rpx;
  color: var(--text-muted);
}
