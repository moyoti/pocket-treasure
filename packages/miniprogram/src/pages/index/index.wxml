<view class="container">
  <!-- Logo和标题 -->
  <view class="hero-section">
    <view class="logo-wrapper">
      <view class="logo-icon">🗺️</view>
      <view class="logo-icon-small">💎</view>
    </view>
    <view class="title">寻宝记</view>
    <view class="subtitle">探索世界，收集宝藏</view>
    <view class="slogan">开启你的探险之旅</view>
  </view>
  
  <!-- 功能介绍 -->
  <view class="features-section">
    <view class="feature-item" wx:for="{{ features }}" wx:key="title">
      <view class="feature-icon">{{ item.icon }}</view>
      <view class="feature-info">
        <view class="feature-title">{{ item.title }}</view>
        <view class="feature-desc">{{ item.desc }}</view>
      </view>
    </view>
  </view>
  
  <!-- 操作按钮 -->
  <view class="action-section">
    <button class="cartoon-btn primary-btn" bindtap="onStartExplore">
      🚀 开始探险
    </button>
    <button class="cartoon-btn secondary-btn" bindtap="onLogin">
      🔐 登录账号
    </button>
  </view>
  
  <!-- 底部提示 -->
  <view class="footer">
    <text class="footer-text">登录后可保存游戏进度</text>
  </view>
</view>
