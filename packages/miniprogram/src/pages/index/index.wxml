<view class="container">
  <!-- Logo和标题 -->
  <view class="hero-section">
    <view class="logo-wrapper">
      <view class="logo-main animate-chest-bounce"><image class="icon-xl" src="/images/icons/map.svg" mode="aspectFit" /></view>
      <view class="logo-sub animate-float"><image class="icon-lg" src="/images/icons/gem.svg" mode="aspectFit" /></view>
    </view>
    <view class="hero-title">附近寻宝</view>
    <view class="hero-subtitle">探索世界，收集宝藏</view>
    <view class="hero-slogan">开启你的探险之旅</view>
  </view>

  <!-- 特色卡片 -->
  <view class="features-grid">
    <view
      class="feature-card animate-slide-in-up stagger-{{ index + 1 }}"
      wx:for="{{ features }}"
      wx:key="title"
      hover-class="feature-card-hover"
      style="background: {{ item.gradient }};"
    >
      <view class="feature-icon-wrap">
        <image class="feature-icon" src="{{ item.icon }}" mode="aspectFit" />
      </view>
      <view class="feature-content">
        <text class="feature-title">{{ item.title }}</text>
        <text class="feature-desc">{{ item.desc }}</text>
      </view>
    </view>
  </view>

  <!-- CTA按钮 -->
  <view class="cta-section">
    <button class="cartoon-btn cta-primary" hover-class="cartoon-btn-hover" bindtap="onStartExplore">
      <image class="icon-sm" src="/images/icons/rocket.svg" mode="aspectFit" /> 开始探险
    </button>
    <button class="cta-secondary" hover-class="cta-secondary-hover" bindtap="onLogin">
      <image class="icon-sm" src="/images/icons/lock.svg" mode="aspectFit" /> 登录账号
    </button>
  </view>

  <!-- 底部提示 -->
  <view class="footer-hint">
    <text class="footer-text">登录后可保存游戏进度</text>
  </view>
</view>
