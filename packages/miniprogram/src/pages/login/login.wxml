<view class="container">
  <view class="logo-section">
    <view class="logo-icons animate-float">
      <view class="logo-map"><image class="icon-xl" src="/images/icons/map.svg" mode="aspectFit" /></view>
      <view class="logo-gem"><image class="icon-lg" src="/images/icons/gem.svg" mode="aspectFit" /></view>
    </view>
    <view class="app-name">附近寻宝</view>
    <view class="app-slogan">探索世界，收集宝藏</view>
  </view>

  <view class="form-card animate-bounce-in">
    <button class="wechat-btn" hover-class="wechat-btn-hover" bindtap="handleWechatLogin" disabled="{{ wechatLoading }}">
      <image class="icon wechat-icon-text" src="/images/icons/smartphone.svg" mode="aspectFit" />
      <text>{{ wechatLoading ? '登录中...' : '微信一键登录' }}</text>
    </button>
  </view>

  <view class="skip-section" bindtap="handleSkip">
    <text class="skip-text">暂不登录，先逛逛 →</text>
  </view>
</view>
