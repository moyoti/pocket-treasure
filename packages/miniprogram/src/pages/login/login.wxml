<view class="container">
  <!-- Logo和标题 -->
  <view class="logo-section">
    <view class="logo-icon">🗺️</view>
    <text class="logo-icon-small">💎</text>
    <view class="title">寻宝记</view>
    <view class="subtitle">探索世界，收集宝藏</view>
  </view>

  <view class="form-card">
    <!-- 微信一键登录（主要方式） -->
    <button class="cartoon-btn wechat-btn" bindtap="handleWechatLogin" disabled="{{ wechatLoading }}">
      <text class="wechat-icon">📱</text> {{ wechatLoading ? '登录中...' : '微信一键登录' }}
    </button>

    <!-- 分隔线 -->
    <view class="divider">
      <view class="divider-line"></view>
      <text class="divider-text">其他登录方式</text>
      <view class="divider-line"></view>
    </view>

    <!-- 邮箱登录/注册表单 -->
    <view class="form-title">{{ isLogin ? '邮箱登录' : '邮箱注册' }}</view>

    <view class="form-item">
      <view class="form-label">📧 邮箱</view>
      <input
        class="cartoon-input"
        type="text"
        placeholder="请输入邮箱"
        value="{{ email }}"
        bindinput="onEmailInput"
      />
    </view>

    <view class="form-item" wx:if="{{ !isLogin }}">
      <view class="form-label">👤 用户名</view>
      <input
        class="cartoon-input"
        type="text"
        placeholder="请输入用户名"
        value="{{ username }}"
        bindinput="onUsernameInput"
      />
    </view>

    <view class="form-item">
      <view class="form-label">🔒 密码</view>
      <input
        class="cartoon-input"
        type="password"
        placeholder="请输入密码"
        value="{{ password }}"
        bindinput="onPasswordInput"
      />
    </view>

    <button class="cartoon-btn submit-btn" bindtap="handleSubmit" disabled="{{ loading }}">
      {{ loading ? '处理中...' : (isLogin ? '🚀 登录' : '✨ 注册') }}
    </button>

    <view class="switch-mode" bindtap="toggleMode">
      {{ isLogin ? '没有账号？立即注册' : '已有账号？立即登录' }}
    </view>

    <!-- 跳过登录 -->
    <view class="skip-login" bindtap="handleSkip">
      暂不登录，先逛逛 →
    </view>
  </view>
</view>
