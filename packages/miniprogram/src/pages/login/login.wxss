.container {
  min-height: 100vh;
  padding: 60rpx 40rpx;
  box-sizing: border-box;
}

.logo-section {
  text-align: center;
  margin-bottom: 60rpx;
  position: relative;
}

.logo-icon {
  width: 160rpx;
  height: 160rpx;
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 80rpx;
  margin: 0 auto;
  border: 8rpx solid var(--border-color);
  box-shadow: 0 8rpx 0 rgba(0, 0, 0, 0.1);
}

.logo-icon-small {
  position: absolute;
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #FCD34D 0%, #F59E0B 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  right: 260rpx;
  top: 80rpx;
  border: 6rpx solid var(--border-color);
}

.title {
  font-size: 64rpx;
  font-weight: 900;
  color: var(--text-primary);
  margin-top: 30rpx;
  text-shadow: 4rpx 4rpx 0 var(--primary-color);
}

.subtitle {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-top: 16rpx;
}

.form-card {
  background: white;
  border-radius: 30rpx;
  padding: 50rpx 40rpx;
  border: 6rpx solid var(--border-color);
  box-shadow: 0 8rpx 0 rgba(0, 0, 0, 0.1);
}

.form-title {
  font-size: 36rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 40rpx;
  color: var(--text-primary);
}

.form-item {
  margin-bottom: 30rpx;
}

.form-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
  font-weight: bold;
}

.cartoon-input {
  width: 100%;
  box-sizing: border-box;
}

.submit-btn {
  width: 100%;
  margin-top: 40rpx;
}

.switch-mode {
  text-align: center;
  margin-top: 30rpx;
  color: var(--text-muted);
  font-size: 26rpx;
}

.divider {
  display: flex;
  align-items: center;
  margin: 40rpx 0;
}

.divider-line {
  flex: 1;
  height: 4rpx;
  background: #E5E7EB;
}

.divider-text {
  padding: 0 30rpx;
  color: var(--text-muted);
  font-size: 24rpx;
}

.wechat-btn {
  background: linear-gradient(180deg, #07C160 0%, #059649 100%);
  color: white;
  position: relative;
}

.wechat-icon {
  margin-right: 16rpx;
}

.skip-login {
  text-align: center;
  margin-top: 40rpx;
  padding: 20rpx;
  color: var(--text-muted);
  font-size: 26rpx;
}
