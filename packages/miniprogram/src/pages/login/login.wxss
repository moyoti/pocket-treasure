/* ===== Icon sizes ===== */
.icon {
  width: 36rpx;
  height: 36rpx;
  vertical-align: middle;
}
.icon-sm {
  width: 28rpx;
  height: 28rpx;
  vertical-align: middle;
}
.icon-lg {
  width: 48rpx;
  height: 48rpx;
  vertical-align: middle;
}
.icon-xl {
  width: 64rpx;
  height: 64rpx;
  vertical-align: middle;
}

.container {
  min-height: 100vh;
  padding: 80rpx 40rpx 40rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* ===== Logo区域 ===== */
.logo-section {
  text-align: center;
  margin-bottom: 50rpx;
}

.logo-icons {
  position: relative;
  display: inline-block;
  margin-bottom: 20rpx;
}

.logo-map {
  width: 140rpx;
  height: 140rpx;
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 72rpx;
  border: 8rpx solid var(--border-color);
  box-shadow: 0 8rpx 0 rgba(0, 0, 0, 0.1);
}

.logo-gem {
  position: absolute;
  right: -30rpx;
  bottom: -10rpx;
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #FCD34D 0%, #F59E0B 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  border: 6rpx solid var(--border-color);
  box-shadow: 0 4rpx 0 rgba(0, 0, 0, 0.1);
}

.app-name {
  font-size: 64rpx;
  font-weight: 900;
  color: var(--text-primary);
  text-shadow: 4rpx 4rpx 0 var(--primary-color), 6rpx 6rpx 0 rgba(0, 0, 0, 0.1);
}

.app-slogan {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-top: 8rpx;
}

/* ===== 表单卡片 ===== */
.form-card {
  width: 100%;
  background: white;
  border-radius: 30rpx;
  padding: 50rpx 40rpx;
  border: 6rpx solid var(--border-color);
  box-shadow: 0 8rpx 0 rgba(0, 0, 0, 0.1);
}

/* ===== 微信登录按钮 ===== */
.wechat-btn {
  width: 100%;
  background: linear-gradient(180deg, #07C160 0%, #059649 100%);
  color: white;
  font-weight: bold;
  font-size: 32rpx;
  padding: 28rpx 0;
  border-radius: 50rpx;
  border: 6rpx solid #046B36;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  letter-spacing: 2rpx;
}

.wechat-btn-hover {
  opacity: 0.85;
  transform: scale(0.98);
}

.wechat-btn[disabled] {
  opacity: 0.6;
}

.wechat-icon-text {
  font-size: 36rpx;
}

/* ===== 分隔线 ===== */
.separator {
  display: flex;
  align-items: center;
  margin: 40rpx 0;
}

.separator-line {
  flex: 1;
  height: 2rpx;
  background: #E5E7EB;
}

.separator-text {
  padding: 0 24rpx;
  font-size: 24rpx;
  color: var(--text-light);
}

/* ===== 表单 ===== */
.form-group {
  margin-bottom: 10rpx;
}

.input-wrapper {
  display: flex;
  align-items: center;
  background: #F9FAFB;
  border: 6rpx solid #E5E7EB;
  border-radius: 24rpx;
  padding: 0 24rpx;
  margin-bottom: 24rpx;
  transition: border-color 0.2s;
}

.input-wrapper:focus-within {
  border-color: var(--primary-color);
}

.input-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.form-input {
  flex: 1;
  height: 88rpx;
  font-size: 28rpx;
  color: var(--text-primary);
}

/* ===== 密码强度 ===== */
.strength-bar {
  margin-top: -8rpx;
  margin-bottom: 24rpx;
  padding: 0 8rpx;
}

.strength-dots {
  display: flex;
  gap: 12rpx;
}

.strength-dot {
  flex: 1;
  height: 8rpx;
  border-radius: 4rpx;
  transition: background-color 0.3s;
}

.strength-text {
  display: block;
  font-size: 22rpx;
  color: var(--text-muted);
  margin-top: 8rpx;
}

/* ===== 提交按钮 ===== */
.submit-btn {
  width: 100%;
  margin-top: 20rpx;
  font-size: 30rpx;
}

/* ===== 切换模式 ===== */
.toggle-mode {
  text-align: center;
  margin-top: 30rpx;
  padding: 10rpx 0;
}

.toggle-text {
  font-size: 26rpx;
  color: var(--text-muted);
}

.toggle-link {
  font-size: 26rpx;
  color: #D97706;
  font-weight: bold;
  text-decoration: underline;
}

/* ===== 社交登录 ===== */
.social-btns {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.social-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 22rpx 0;
  border-radius: 50rpx;
  font-size: 28rpx;
  font-weight: bold;
  border: 6rpx solid #E5E7EB;
  background: white;
}

.social-btn[disabled] {
  opacity: 0.5;
}

.google-btn {
  background: white;
  color: var(--text-primary);
}

.apple-btn {
  background: linear-gradient(180deg, #333 0%, #111 100%);
  color: white;
  border-color: #333;
}

.social-icon {
  font-size: 32rpx;
  font-weight: 900;
}

.social-label {
  font-size: 28rpx;
}

.social-hint {
  font-size: 20rpx;
  opacity: 0.6;
}

/* ===== 跳过登录 ===== */
.skip-section {
  margin-top: 40rpx;
  padding: 20rpx;
}

.skip-text {
  font-size: 26rpx;
  color: var(--text-muted);
}
