<!--pages/market/market.wxml-->
<view class="market-container">
  <!-- 头部 -->
  <view class="header cartoon-card">
    <view class="back-btn" bindtap="goBack">‹</view>
    <text class="header-title">🏪 玩家市场</text>
    <view class="coin-display">
      <image class="coin-icon" src="/assets/icons/coin.png" mode="aspectFit" />
      <text class="coin-amount">{{ balance }}</text>
    </view>
  </view>

  <!-- 切换标签 -->
  <view class="tab-bar cartoon-card">
    <view class="tab-item {{ activeTab === 'buy' ? 'active' : '' }}" data-tab="buy" bindtap="switchTab">购买</view>
    <view class="tab-item {{ activeTab === 'sell' ? 'active' : '' }}" data-tab="sell" bindtap="switchTab">出售</view>
  </view>

  <!-- 购买列表 -->
  <view class="listings-list" wx:if="{{ activeTab === 'buy' }}">
    <block wx:if="{{ listings.length > 0 }}">
      <view class="listing-card cartoon-card" wx:for="{{ listings }}" wx:key="id" data-item="{{ item }}" bindtap="buyItem">
        <view class="listing-icon">💎</view>
        <view class="listing-info">
          <view class="listing-name">{{ item.item.name }}</view>
          <view class="listing-meta">
            <text class="listing-seller">{{ item.seller.username }}</text>
            <text class="listing-qty">x{{ item.quantity }}</text>
          </view>
        </view>
        <view class="listing-price">
          <image class="coin-icon-small" src="/assets/icons/coin.png" />
          <text>{{ item.price }}</text>
        </view>
      </view>
    </block>
    <view class="empty-state" wx:else>
      <view class="empty-icon">🏪</view>
      <text class="empty-text">暂无商品</text>
    </view>
  </view>

  <!-- 出售列表 -->
  <view class="my-items-list" wx:if="{{ activeTab === 'sell' }}">
    <block wx:if="{{ myItems.length > 0 }}">
      <view class="my-item-card cartoon-card" wx:for="{{ myItems }}" wx:key="id" data-item="{{ item }}" bindtap="openSellModal">
        <view class="item-icon">💎</view>
        <view class="item-info">
          <view class="item-name">{{ item.item.name }}</view>
          <view class="item-qty">x{{ item.quantity }}</view>
        </view>
        <button class="cartoon-btn sell-btn">上架</button>
      </view>
    </block>
    <view class="empty-state" wx:else>
      <view class="empty-icon">📦</view>
      <text class="empty-text">背包为空</text>
    </view>
  </view>

  <!-- 上架弹窗 -->
  <view class="modal-overlay" wx:if="{{ sellModal.isOpen }}" bindtap="closeSellModal">
    <view class="modal-content cartoon-card" catchtap="">
      <view class="modal-title">上架商品</view>

      <view class="item-preview">
        <view class="preview-icon">💎</view>
        <view class="preview-info">
          <text class="preview-name">{{ sellModal.item.item.name }}</text>
          <text class="preview-qty">拥有: {{ sellModal.item.quantity }}</text>
        </view>
      </view>

      <view class="form-group">
        <text class="form-label">价格</text>
        <input class="form-input" type="number" value="{{ sellModal.price }}" bindinput="onPriceInput" />
      </view>

      <view class="price-note">
        <text>手续费: 10%</text>
        <text>实际获得: {{ Math.floor(sellModal.price * 0.9) }} 金币</text>
      </view>

      <view class="modal-buttons">
        <button class="cartoon-btn cartoon-btn-secondary" bindtap="closeSellModal">取消</button>
        <button class="cartoon-btn" bindtap="confirmSell">确认上架</button>
      </view>
    </view>
  </view>

  <!-- 加载中 -->
  <view class="loading-overlay" wx:if="{{ loading }}">
    <view class="loading-spinner"></view>
  </view>
</view>