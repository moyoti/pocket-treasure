<view class="container">
  <!-- 常见问题 -->
  <view class="section-label">
    <image class="icon section-label-icon" src="/images/icons/help-circle.svg" mode="aspectFit" />
    <text>常见问题</text>
  </view>

  <view
    class="faq-card"
    wx:for="{{ faqs }}"
    wx:key="question"
    bindtap="toggleFaq"
    data-index="{{ index }}"
  >
    <view class="faq-header">
      <view class="faq-icon" style="background-color: {{ item.bg }};">
        <image class="icon" src="{{ item.icon }}" mode="aspectFit" />
      </view>
      <text class="faq-question">{{ item.question }}</text>
      <text class="faq-arrow {{ item.expanded ? 'faq-arrow-open' : '' }}">›</text>
    </view>
    <view class="faq-answer {{ item.expanded ? 'faq-answer-show' : '' }}">
      <text class="faq-answer-text">{{ item.answer }}</text>
    </view>
  </view>

  <!-- 游戏规则 -->
  <view class="section-label" style="margin-top: 40rpx;">
    <image class="icon section-label-icon" src="/images/icons/shield.svg" mode="aspectFit" />
    <text>游戏规则</text>
  </view>

  <view class="rules-card">
    <view class="rule-item" wx:for="{{ rules }}" wx:key="title">
      <view class="rule-icon" style="background-color: {{ item.bg }};">
        <image class="icon" src="{{ item.icon }}" mode="aspectFit" />
      </view>
      <view class="rule-info">
        <text class="rule-title">{{ item.title }}</text>
        <text class="rule-desc">{{ item.desc }}</text>
      </view>
    </view>
  </view>

  <!-- 联系我们 -->
  <view class="section-label" style="margin-top: 40rpx;">
    <image class="icon section-label-icon" src="/images/icons/message-circle.svg" mode="aspectFit" />
    <text>联系我们</text>
  </view>

  <view class="contact-card">
    <view class="contact-item">
      <view class="contact-icon" style="background-color: #DBEAFE;">
        <image class="icon" src="/images/icons/mail.svg" mode="aspectFit" />
      </view>
      <view class="contact-info">
        <text class="contact-title">电子邮箱</text>
        <text class="contact-value">support@treasurehunt.game</text>
      </view>
    </view>
    <view class="contact-item">
      <view class="contact-icon" style="background-color: #D1FAE5;">
        <image class="icon" src="/images/icons/message-circle.svg" mode="aspectFit" />
      </view>
      <view class="contact-info">
        <text class="contact-title">官方社区</text>
        <text class="contact-value">加入我们的 Discord 社区</text>
      </view>
    </view>
  </view>

  <!-- 小提示 -->
  <view class="tip-card">
    <image class="icon tip-icon" src="/images/icons/lightbulb.svg" mode="aspectFit" />
    <text class="tip-text">记得经常查看地图，宝藏会定期刷新。探索新的区域可以发现更多稀有宝藏！</text>
  </view>

  <text class="version-text">宝藏地图 v1.0.0</text>
</view>
