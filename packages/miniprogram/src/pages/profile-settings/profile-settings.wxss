.icon {
  width: 36rpx;
  height: 36rpx;
  vertical-align: middle;
}
.icon-sm {
  width: 28rpx;
  height: 28rpx;
}
.icon-lg {
  width: 48rpx;
  height: 48rpx;
}
.icon-xl {
  width: 64rpx;
  height: 64rpx;
}

.container {
  min-height: 100vh;
  padding: 24rpx;
  padding-bottom: 120rpx;
}

/* Section */
.section {
  background: white;
  border-radius: 24rpx;
  border: 6rpx solid var(--border-color);
  box-shadow: 0 8rpx 0 rgba(0, 0, 0, 0.1);
  margin-bottom: 24rpx;
  overflow: hidden;
}

.section-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 24rpx 30rpx;
  border-bottom: 4rpx solid var(--border-color);
}

.section-header-yellow {
  background: linear-gradient(135deg, #FEF3C7 0%, #FDE68A 100%);
}

.section-header-green {
  background: linear-gradient(135deg, #D1FAE5 0%, #A7F3D0 100%);
}

.section-header-purple {
  background: linear-gradient(135deg, #EDE9FE 0%, #DDD6FE 100%);
}

.section-header-blue {
  background: linear-gradient(135deg, #DBEAFE 0%, #BFDBFE 100%);
}

.section-header-red {
  background: linear-gradient(135deg, #FEE2E2 0%, #FECACA 100%);
}

.section-icon {
  flex-shrink: 0;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--text-primary);
}

.section-body {
  padding: 20rpx 30rpx;
}

/* Setting Item */
.setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
}

.setting-info {
  flex: 1;
  margin-right: 20rpx;
}

.setting-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: var(--text-primary);
}

.setting-desc {
  display: block;
  font-size: 22rpx;
  color: var(--text-muted);
  margin-top: 4rpx;
}

.setting-divider {
  height: 2rpx;
  background: #F3F4F6;
}

/* Toggle */
.toggle {
  width: 96rpx;
  height: 52rpx;
  border-radius: 26rpx;
  background: #D1D5DB;
  border: 4rpx solid var(--border-color);
  position: relative;
  transition: background 0.2s;
  flex-shrink: 0;
}

.toggle-on {
  background: #4ADE80;
}

.toggle-dot {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: white;
  border: 4rpx solid var(--border-color);
  position: absolute;
  top: 2rpx;
  left: 2rpx;
  transition: transform 0.2s;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

.toggle-on .toggle-dot {
  transform: translateX(44rpx);
}

/* Zoom Slider */
.zoom-slider {
  margin: 10rpx 0 20rpx;
}

/* Language Grid */
.lang-grid {
  display: flex;
  gap: 20rpx;
  padding: 10rpx 0;
}

.lang-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 24rpx 16rpx;
  border-radius: 20rpx;
  border: 4rpx solid var(--border-color);
  background: white;
}

.lang-item-active {
  background: #FEF3C7;
  border-color: #F59E0B;
}

.lang-flag-icon {
  display: block;
}

.lang-name {
  font-size: 24rpx;
  font-weight: bold;
  color: var(--text-primary);
}

/* Buttons */
.btn-group {
  margin-top: 30rpx;
}

.save-btn {
  width: 100%;
  margin-bottom: 20rpx;
}

.reset-btn {
  width: 100%;
  text-align: center;
  padding: 28rpx;
  border-radius: 24rpx;
  border: 4rpx solid #FCA5A5;
  color: #DC2626;
  font-size: 28rpx;
  font-weight: bold;
  background: white;
}
