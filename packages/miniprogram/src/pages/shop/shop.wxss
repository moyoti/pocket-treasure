.btn-inner {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
}

.login-hint-inner {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.container {
  min-height: 100vh;
  padding-bottom: 120rpx;
}

/* ===== Header ===== */
.header {
  background: white;
  padding: 24rpx 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 6rpx solid var(--border-color);
  position: sticky;
  top: 0;
  z-index: 40;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.title-icon {
  font-size: 40rpx;
}

.title-text {
  font-size: 36rpx;
  font-weight: 900;
  color: var(--text-primary);
}

.balance-pill {
  display: flex;
  align-items: center;
  gap: 10rpx;
  background: linear-gradient(135deg, #FEF3C7 0%, #FDE68A 100%);
  padding: 14rpx 28rpx;
  border-radius: 50rpx;
  border: 6rpx solid #F59E0B;
}

.balance-icon {
  font-size: 28rpx;
}

.balance-value {
  font-size: 28rpx;
  font-weight: 900;
  color: #92400E;
}

.login-hint {
  background: linear-gradient(135deg, #FEF3C7 0%, #FDE68A 100%);
  padding: 14rpx 28rpx;
  border-radius: 50rpx;
  border: 4rpx solid #F59E0B;
  font-size: 24rpx;
  font-weight: 700;
  color: #92400E;
}

/* ===== Empty State ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx;
}

.empty-icon-circle {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: #F3F4F6;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 8rpx solid #D1D5DB;
  margin-bottom: 30rpx;
}

.empty-icon-text {
  font-size: 72rpx;
}

.empty-state-text {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-secondary);
}

.empty-state-subtext {
  font-size: 26rpx;
  color: var(--text-muted);
  margin-top: 12rpx;
}

/* ===== Shop Grid ===== */
.shop-grid {
  padding: 20rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.shop-card {
  width: calc(50% - 10rpx);
  background: white;
  border-radius: 24rpx;
  border: 6rpx solid var(--border-color);
  padding: 24rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  position: relative;
}

.category-tag {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
  font-weight: 700;
  border: 3rpx solid currentColor;
}

.shop-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid var(--border-color);
  margin-top: 16rpx;
}

.shop-icon-emoji {
  font-size: 48rpx;
}

.shop-name {
  font-size: 28rpx;
  font-weight: 900;
  color: var(--text-primary);
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 100%;
}

.shop-rarity {
  font-size: 22rpx;
  font-weight: 700;
}

.shop-desc {
  font-size: 22rpx;
  color: var(--text-muted);
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.shop-price-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  padding-top: 12rpx;
  border-top: 4rpx solid #F3F4F6;
}

.shop-price {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.price-coin {
  font-size: 22rpx;
}

.price-amount {
  font-size: 26rpx;
  font-weight: 900;
  color: #92400E;
}

.shop-limit {
  font-size: 20rpx;
  color: var(--text-muted);
}

.shop-buy-btn {
  width: 100%;
  padding: 18rpx;
  text-align: center;
  border-radius: 50rpx;
  border: 6rpx solid var(--border-color);
  font-size: 26rpx;
  font-weight: 700;
  background: linear-gradient(180deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  color: var(--text-primary);
  margin-top: auto;
}

.shop-buy-btn.disabled {
  opacity: 0.5;
  background: #E5E7EB;
}

/* ===== Modal ===== */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  padding: 40rpx;
}

.modal-content {
  background: white;
  border-radius: 30rpx;
  border: 6rpx solid var(--border-color);
  padding: 40rpx;
  width: 100%;
  max-width: 600rpx;
  box-shadow: 0 16rpx 0 rgba(0, 0, 0, 0.1);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 900;
  color: var(--text-primary);
}

.modal-close {
  font-size: 36rpx;
  color: var(--text-muted);
  padding: 10rpx;
}

.purchase-preview {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
  background: #F9FAFB;
  border-radius: 20rpx;
  border: 4rpx solid #E5E7EB;
  margin-bottom: 30rpx;
}

.preview-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid var(--border-color);
  font-size: 40rpx;
}

.preview-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.preview-name {
  font-size: 28rpx;
  font-weight: 900;
  color: var(--text-primary);
}

.preview-category {
  font-size: 24rpx;
  font-weight: 700;
}

.qty-controls {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 32rpx;
  margin-bottom: 30rpx;
}

.qty-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  border: 6rpx solid var(--border-color);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 900;
  background: white;
}

.qty-value {
  font-size: 48rpx;
  font-weight: 900;
  color: var(--text-primary);
  min-width: 60rpx;
  text-align: center;
}

.purchase-total {
  background: #FEF3C7;
  border-radius: 20rpx;
  padding: 24rpx;
  border: 4rpx solid #FDE68A;
  margin-bottom: 30rpx;
}

.total-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.total-label {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--text-secondary);
}

.total-value {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.total-coin {
  font-size: 28rpx;
}

.total-amount {
  font-size: 40rpx;
  font-weight: 900;
  color: #92400E;
}

.insufficient-text {
  display: block;
  font-size: 24rpx;
  font-weight: 700;
  color: #EF4444;
  margin-top: 12rpx;
}

.modal-buttons {
  display: flex;
  gap: 20rpx;
}

.modal-btn-cancel {
  flex: 1;
  padding: 24rpx;
  text-align: center;
  border-radius: 20rpx;
  border: 6rpx solid var(--border-color);
  font-size: 28rpx;
  font-weight: 700;
  background: white;
}

.modal-btn-confirm {
  flex: 1;
  padding: 24rpx;
  text-align: center;
  border-radius: 20rpx;
  border: 6rpx solid var(--border-color);
  font-size: 28rpx;
  font-weight: 700;
  background: linear-gradient(180deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  color: var(--text-primary);
}

.modal-btn-confirm.disabled {
  opacity: 0.5;
}

/* ===== Success Modal ===== */
.success-modal {
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.success-icon-circle {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #D1FAE5;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 8rpx solid #10B981;
  font-size: 56rpx;
  color: #10B981;
  margin-bottom: 24rpx;
}

.success-title {
  font-size: 36rpx;
  font-weight: 900;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.success-msg {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 30rpx;
}

/* Loading */
.loading-container {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}
