<view class="container">
  <!-- 顶部栏 -->
  <view class="header">
    <view class="header-left">
      <image class="icon-lg title-icon" src="/images/icons/store.svg" mode="aspectFit" />
      <text class="title-text">NPC商店</text>
    </view>
    <view class="balance-pill" wx:if="{{ isLoggedIn }}">
      <image class="icon-sm" src="/images/icons/coins.svg" mode="aspectFit" />
      <text class="balance-value">{{ balance }}</text>
    </view>
    <view class="login-hint" wx:else bindtap="goToLogin">
      <view class="login-hint-inner">
        <image class="icon-sm" src="/images/icons/lock.svg" mode="aspectFit" />
        <text> 登录购买</text>
      </view>
    </view>
  </view>

  <!-- 加载中 -->
  <view class="loading-container" wx:if="{{ loading }}">
    <view class="cartoon-loader"></view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:elif="{{ items.length === 0 }}">
    <view class="empty-icon-circle">
      <image class="icon-xl" src="/images/icons/store.svg" mode="aspectFit" />
    </view>
    <view class="empty-state-text">商店暂无商品</view>
    <view class="empty-state-subtext">请稍后再来看看！</view>
  </view>

  <!-- 商品网格 -->
  <view class="shop-grid animate-page-enter" wx:else>
    <view
      class="shop-card"
      wx:for="{{ items }}"
      wx:key="id"
    >
      <!-- 分类标签 -->
      <view class="category-tag {{ item.rarityBgClass }}">
        <text style="color: {{ item.rarityColor }};">{{ item.categoryLabel }}</text>
      </view>

      <!-- 物品图标 -->
      <view class="shop-icon {{ item.rarityBgClass }}">
        <image class="icon-lg" src="{{ item.icon || '/images/icons/gift.svg' }}" mode="aspectFit" />
      </view>

      <!-- 物品信息 -->
      <text class="shop-name">{{ item.name }}</text>
      <text class="shop-rarity" style="color: {{ item.rarityColor }};">{{ item.rarityName }}</text>
      <text class="shop-desc">{{ item.description }}</text>

      <!-- 价格和限购 -->
      <view class="shop-price-row">
        <view class="shop-price">
          <image class="icon-sm" src="/images/icons/coins.svg" mode="aspectFit" />
          <text class="price-amount">{{ item.price }}</text>
        </view>
        <text class="shop-limit">{{ item.limitText }}</text>
      </view>

      <!-- 购买按钮 -->
      <view
        class="shop-buy-btn {{ !item.isAvailable || balance < item.price ? 'disabled' : '' }}"
        bindtap="openPurchaseModal"
        data-index="{{ index }}"
      >
        <text wx:if="{{ !item.isAvailable }}">已售罄</text>
        <text wx:elif="{{ balance < item.price }}">金币不足</text>
        <text wx:else>购买</text>
      </view>
    </view>
  </view>

  <!-- 购买模态框 -->
  <view class="modal-overlay" wx:if="{{ purchaseModalOpen }}" catchtap="closePurchaseModal">
    <view class="modal-content animate-bounce-in" catchtap="">
      <view class="modal-header">
        <text class="modal-title">确认购买</text>
        <view class="modal-close" bindtap="closePurchaseModal">
          <image class="icon" src="/images/icons/x.svg" mode="aspectFit" />
        </view>
      </view>

      <view class="purchase-preview" wx:if="{{ purchaseItemData }}">
        <view class="preview-icon {{ purchaseItemData.rarityBgClass }}">
          <image class="icon-lg" src="{{ purchaseItemData.icon || '/images/icons/gift.svg' }}" mode="aspectFit" />
        </view>
        <view class="preview-info">
          <text class="preview-name">{{ purchaseItemData.name }}</text>
          <text class="preview-category" style="color: {{ purchaseItemData.rarityColor }};">{{ purchaseItemData.categoryLabel }}</text>
        </view>
      </view>

      <!-- 数量选择 -->
      <view class="qty-controls">
        <view class="qty-btn" bindtap="decreasePurchaseQty">-</view>
        <text class="qty-value">{{ purchaseQty }}</text>
        <view class="qty-btn" bindtap="increasePurchaseQty">+</view>
      </view>

      <!-- 总价 -->
      <view class="purchase-total">
        <view class="total-row">
          <text class="total-label">总计:</text>
          <view class="total-value">
            <image class="icon" src="/images/icons/coins.svg" mode="aspectFit" />
            <text class="total-amount">{{ purchaseTotalPrice }}</text>
          </view>
        </view>
        <text class="insufficient-text" wx:if="{{ !canAfford }}">金币不足！</text>
      </view>

      <!-- 按钮 -->
      <view class="modal-buttons">
        <view class="modal-btn-cancel" bindtap="closePurchaseModal">取消</view>
        <view class="modal-btn-confirm {{ purchaseLoading || !canAfford ? 'disabled' : '' }}" bindtap="confirmPurchase">
          <view wx:if="{{ !purchaseLoading }}" class="btn-inner">
            <image class="icon-sm" src="/images/icons/check.svg" mode="aspectFit" />
            <text> 确认</text>
          </view>
          <text wx:else>购买中...</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 成功模态框 -->
  <view class="modal-overlay" wx:if="{{ successModalOpen }}" catchtap="closeSuccessModal">
    <view class="modal-content animate-bounce-in success-modal" catchtap="">
      <view class="success-icon-circle">
        <image class="icon-lg" src="/images/icons/check.svg" mode="aspectFit" />
      </view>
      <text class="success-title">购买成功！</text>
      <text class="success-msg">{{ successMessage }}</text>
      <view class="modal-btn-confirm" bindtap="closeSuccessModal">确定</view>
    </view>
  </view>
</view>
