/* pages/leaderboard/leaderboard.wxss */

.leaderboard-container {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* ===== Header ===== */
.header {
  background: white;
  padding: 24rpx 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 6rpx solid var(--border-color);
  position: sticky;
  top: 0;
  z-index: 40;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.title-icon {
  font-size: 40rpx;
}

.title-text {
  font-size: 36rpx;
  font-weight: 900;
  color: var(--text-primary);
}

.header-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.balance-pill {
  display: flex;
  align-items: center;
  gap: 10rpx;
  background: linear-gradient(135deg, #FEF3C7 0%, #FDE68A 100%);
  padding: 14rpx 28rpx;
  border-radius: 50rpx;
  border: 6rpx solid #F59E0B;
}

.balance-icon {
  font-size: 28rpx;
}

.balance-value {
  font-size: 28rpx;
  font-weight: 900;
  color: #92400E;
}

/* 我的排名卡片 */
.my-rank-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.my-rank-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.my-rank-avatar {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #F59E0B, #EA580C);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid var(--border-color);
}

.my-rank-avatar-letter {
  font-size: 28rpx;
  font-weight: 900;
  color: white;
}

.my-rank-info {
  display: flex;
  flex-direction: column;
}

.my-rank-label {
  font-size: 22rpx;
  color: var(--text-muted);
  font-weight: 500;
}

.my-rank-name {
  font-size: 30rpx;
  font-weight: 900;
  color: var(--text-primary);
}

.my-rank-right {
  text-align: right;
}

.my-rank-number {
  font-size: 56rpx;
  font-weight: 900;
  color: #D97706;
}

/* 领奖台 */
.podium-card {
  padding: 40rpx 20rpx 0;
}

.podium-row {
  display: flex;
  align-items: flex-end;
  justify-content: center;
  gap: 16rpx;
}

.podium-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.podium-placeholder {
  flex: 1;
}

.podium-crown-icon {
  margin-bottom: 8rpx;
}

/* 头像 */
.podium-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 6rpx solid var(--border-color);
  margin-bottom: 12rpx;
}

.podium-avatar-gold {
  width: 112rpx;
  height: 112rpx;
  background: linear-gradient(135deg, #FFD93D, #F59E0B);
  box-shadow: 0 8rpx 24rpx rgba(245, 158, 11, 0.4);
}

.podium-avatar-silver {
  background: linear-gradient(135deg, #E5E7EB, #9CA3AF);
  box-shadow: 0 6rpx 16rpx rgba(156, 163, 175, 0.4);
}

.podium-avatar-bronze {
  background: linear-gradient(135deg, #FDBA74, #EA580C);
  box-shadow: 0 6rpx 16rpx rgba(234, 88, 12, 0.3);
}

.podium-avatar-letter {
  font-size: 36rpx;
  font-weight: 900;
  color: white;
}

.podium-avatar-letter-gold {
  font-size: 42rpx;
  font-weight: 900;
  color: #78350F;
}

/* 用户名 */
.podium-name {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--text-secondary);
  max-width: 160rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  text-align: center;
}

.podium-name-gold {
  color: var(--text-primary);
}

/* 收集数 */
.podium-count-row {
  display: flex;
  align-items: center;
  gap: 6rpx;
  margin-top: 6rpx;
}

.podium-count {
  font-size: 22rpx;
  font-weight: 700;
}

.gold-text {
  color: #D97706;
}

.silver-text {
  color: #6B7280;
}

.bronze-text {
  color: #EA580C;
}

/* 领奖台柱子 */
.podium-bar {
  width: 100%;
  border-radius: 16rpx 16rpx 0 0;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 16rpx;
}

.podium-bar-gold {
  height: 176rpx;
  background: linear-gradient(to top, #F59E0B, #FFD93D);
  border: 4rpx solid #D97706;
  border-bottom: none;
}

.podium-bar-silver {
  height: 128rpx;
  background: linear-gradient(to top, #9CA3AF, #E5E7EB);
  border: 4rpx solid #9CA3AF;
  border-bottom: none;
}

.podium-bar-bronze {
  height: 96rpx;
  background: linear-gradient(to top, #EA580C, #FDBA74);
  border: 4rpx solid #EA580C;
  border-bottom: none;
}

.podium-rank-text {
  font-size: 44rpx;
  font-weight: 900;
  color: #78350F;
}

.podium-medal-icon {
  display: block;
}

/* 排名列表 */
.rest-list {
  padding: 0 4rpx;
}

.rank-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-top: 0;
  margin-bottom: 12rpx;
}

.rank-card-highlight {
  border-color: #F59E0B !important;
  border-width: 8rpx !important;
  background: #FFFBEB !important;
}

.rank-badge {
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  background: #F3F4F6;
  border: 4rpx solid #D1D5DB;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.rank-badge-text {
  font-size: 24rpx;
  font-weight: 900;
  color: var(--text-muted);
}

.rank-user-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.rank-username {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.rank-stats {
  font-size: 22rpx;
  color: var(--text-muted);
  margin-top: 4rpx;
}

.rank-score {
  font-size: 36rpx;
  font-weight: 900;
  color: #D97706;
  flex-shrink: 0;
}

/* 空状态 */
.empty-icon-text {
  font-size: 80rpx;
}

.empty-btn {
  margin-top: 30rpx;
}
