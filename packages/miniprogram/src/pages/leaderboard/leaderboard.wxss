/* pages/leaderboard/leaderboard.wxss */

.leaderboard-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #FFF8E7 0%, #FFE4B5 100%);
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.back-btn {
  font-size: 40rpx;
  color: #333;
  padding: 8rpx 16rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.placeholder {
  width: 56rpx;
}

.leaderboard-list {
  padding: 16rpx;
}

.rank-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 12rpx;
}

.rank-card.top-rank {
  background: linear-gradient(135deg, #FEF3C7 0%, #FDE68A 100%);
}

.rank-number {
  width: 48rpx;
  height: 48rpx;
  background: #e5e7eb;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: bold;
  color: #333;
}

.rank-card.top-rank .rank-number {
  background: linear-gradient(135deg, #FF6B35 0%, #FF8F5E 100%);
  color: white;
}

.rank-avatar {
  width: 64rpx;
  height: 64rpx;
  background: linear-gradient(135deg, #A855F7 0%, #C084FC 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: bold;
  color: white;
  font-size: 28rpx;
}

.rank-info {
  flex: 1;
}

.rank-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.rank-stats {
  font-size: 22rpx;
  color: #666;
  margin-top: 4rpx;
}

.rank-score {
  font-size: 32rpx;
  font-weight: bold;
  color: #FF6B35;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #666;
}

/* 加载 */
.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid #f3f3f3;
  border-top: 6rpx solid #FF6B35;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}