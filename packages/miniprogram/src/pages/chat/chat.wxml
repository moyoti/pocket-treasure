<view class="container">
  <!-- 消息列表 -->
  <view class="messages">
    <view class="loading-container" wx:if="{{ loading }}">
      <view class="loading-spinner"></view>
    </view>
    
    <view class="empty-state" wx:elif="{{ messages.length === 0 }}">
      <view class="empty-state-icon">💬</view>
      <view class="empty-state-text">暂无消息</view>
      <view class="empty-state-subtext">发送一条消息开始对话</view>
    </view>
    
    <view wx:else>
      <view class="message {{ item.senderId === userId ? 'received' : 'sent' }}" wx:for="{{ messages }}" wx:key="id">
        <view class="message-bubble">
          <view class="message-content">{{ item.content }}</view>
          <view class="message-time">{{ item.createdAt }}</view>
        </view>
      </view>
    </view>
  </view>
  
  <!-- 输入框 -->
  <view class="input-bar">
    <input 
      class="message-input" 
      placeholder="输入消息..." 
      value="{{ inputText }}"
      bindinput="onInputChange"
      bindconfirm="handleSend"
    />
    <button class="send-btn" bindtap="handleSend" disabled="{{ !inputText.trim() || sending }}">
      {{ sending ? '...' : '发送' }}
    </button>
  </view>
</view>
