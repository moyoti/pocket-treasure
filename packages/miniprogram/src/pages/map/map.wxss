/* ===== Icon sizes ===== */
.icon {
  width: 36rpx;
  height: 36rpx;
  vertical-align: middle;
}
.icon-sm {
  width: 28rpx;
  height: 28rpx;
  vertical-align: middle;
}
.icon-lg {
  width: 48rpx;
  height: 48rpx;
  vertical-align: middle;
}
.icon-xl {
  width: 64rpx;
  height: 64rpx;
  vertical-align: middle;
}

.container {
  width: 100vw;
  height: 100vh;
  position: relative;
  overflow: hidden;
}

.map {
  width: 100%;
  height: 100%;
}

/* ===== 顶部悬浮UI层 ===== */
.top-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  padding: 20rpx 24rpx;
  padding-top: calc(20rpx + env(safe-area-inset-top));
  display: flex;
  justify-content: space-between;
  align-items: center;
  z-index: 10;
  pointer-events: none;
}

.top-overlay > view {
  pointer-events: auto;
}

.pool-btn {
  background: white;
  border-radius: 50rpx;
  padding: 14rpx 28rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
  border: 4rpx solid var(--border-color);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.12);
}

.pool-btn-hover {
  opacity: 0.8;
  transform: scale(0.96);
}

.pool-icon {
  font-size: 28rpx;
}

.pool-text {
  font-size: 26rpx;
  font-weight: bold;
  color: var(--text-primary);
}

.refresh-btn {
  background: white;
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid var(--border-color);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.12);
}

.refresh-btn-hover {
  opacity: 0.8;
  transform: scale(0.96);
}

.refresh-icon {
  font-size: 36rpx;
}

.refresh-spinning {
  animation: spin 1s linear infinite;
}

/* ===== 信息栏 ===== */
.info-bar {
  position: absolute;
  top: calc(100rpx + env(safe-area-inset-top));
  left: 0;
  right: 0;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  z-index: 10;
  flex-wrap: wrap;
  pointer-events: none;
}

.info-bar > view {
  pointer-events: auto;
}

.balance-pill,
.login-pill,
.count-pill,
.coord-pill {
  background: white;
  border-radius: 50rpx;
  padding: 12rpx 24rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  border: 4rpx solid var(--border-color);
  box-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.1);
}

.balance-icon,
.count-icon,
.coord-icon,
.login-pill-icon {
  font-size: 28rpx;
}

.balance-value {
  font-size: 28rpx;
  font-weight: bold;
  color: #D97706;
}

.login-pill {
  background: linear-gradient(135deg, #FEF3C7 0%, #FCD34D 100%);
  border-color: #F59E0B;
}

.login-pill-text {
  font-size: 24rpx;
  font-weight: bold;
  color: #92400E;
}

.count-value {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--text-primary);
}

.count-label {
  font-size: 22rpx;
  color: var(--text-muted);
}

.coord-text {
  font-size: 22rpx;
  color: var(--text-secondary);
  font-weight: 600;
}

/* ===== 稀有度图例 ===== */
.rarity-legend {
  position: absolute;
  bottom: 40rpx;
  left: 24rpx;
  background: rgba(255, 255, 255, 0.92);
  border-radius: 20rpx;
  padding: 16rpx 24rpx;
  border: 4rpx solid var(--border-color);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  z-index: 10;
}

.legend-title {
  font-size: 20rpx;
  font-weight: bold;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 2rpx;
  margin-bottom: 10rpx;
}

.legend-items {
  display: flex;
  gap: 16rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.legend-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  border: 3rpx solid var(--border-color);
}

.legend-name {
  font-size: 20rpx;
  font-weight: bold;
  color: var(--text-secondary);
}

/* ===== 附近物品列表面板 ===== */
.item-pool-panel {
  position: absolute;
  top: calc(180rpx + env(safe-area-inset-top));
  left: 24rpx;
  width: 400rpx;
  max-height: 500rpx;
  background: white;
  border-radius: 24rpx;
  border: 4rpx solid var(--border-color);
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.15);
  z-index: 20;
  transform: translateX(-120%) scale(0.9);
  opacity: 0;
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  overflow: hidden;
}

.panel-visible {
  transform: translateX(0) scale(1);
  opacity: 1;
}

.panel-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 28rpx;
  border-bottom: 4rpx solid #F3F4F6;
}

.panel-title {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--text-primary);
}

.panel-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: var(--text-muted);
  border-radius: 50%;
  background: #F3F4F6;
}

.panel-scroll {
  max-height: 400rpx;
  padding: 12rpx 0;
}

.panel-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
}

.panel-empty-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.panel-empty-text {
  font-size: 26rpx;
  color: var(--text-muted);
}

.panel-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 16rpx 28rpx;
}

.panel-item-icon {
  width: 60rpx;
  height: 60rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  border: 3rpx solid var(--border-color);
  flex-shrink: 0;
}

.panel-item-info {
  flex: 1;
}

.panel-item-name {
  font-size: 26rpx;
  font-weight: bold;
  color: var(--text-primary);
  display: block;
}

.panel-item-rarity {
  font-size: 22rpx;
  font-weight: bold;
  display: block;
  margin-top: 4rpx;
}

/* ===== 未登录提示 ===== */
.guest-hint {
  position: absolute;
  bottom: 40rpx;
  left: 30rpx;
  right: 30rpx;
  z-index: 10;
}

.hint-content {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 24rpx 30rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  border: 4rpx solid var(--border-color);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.hint-icon {
  font-size: 36rpx;
}

.hint-text {
  flex: 1;
  font-size: 26rpx;
  color: var(--text-secondary);
}

.hint-btn {
  background: var(--primary-color);
  color: var(--text-primary);
  font-size: 24rpx;
  font-weight: bold;
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
  border: 4rpx solid var(--border-color);
}

.hint-btn-hover {
  opacity: 0.85;
}

/* ===== 加载覆盖 ===== */
.loading-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.9);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.loading-text {
  margin-top: 30rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
}

/* ===== 宝藏详情底部滑出面板 ===== */
.item-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 50;
  pointer-events: none;
}

.modal-visible {
  pointer-events: auto;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.3);
  opacity: 0;
  transition: opacity 0.3s;
}

.modal-visible .modal-mask {
  opacity: 1;
}

.modal-sheet {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: white;
  border-radius: 40rpx 40rpx 0 0;
  padding: 20rpx 40rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  border-top: 6rpx solid var(--border-color);
  box-shadow: 0 -8rpx 30rpx rgba(0, 0, 0, 0.15);
  transform: translateY(100%);
  transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.modal-visible .modal-sheet {
  transform: translateY(0);
}

.sheet-handle {
  width: 60rpx;
  height: 8rpx;
  background: #D1D5DB;
  border-radius: 4rpx;
  margin: 0 auto 30rpx;
}

.sheet-body {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.sheet-icon-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 6rpx solid var(--border-color);
  margin-bottom: 20rpx;
}

.sheet-icon-emoji {
  font-size: 56rpx;
}

.sheet-name {
  font-size: 40rpx;
  font-weight: 900;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.sheet-rarity-badge {
  margin-bottom: 16rpx;
}

.sheet-desc {
  font-size: 28rpx;
  color: var(--text-secondary);
  text-align: center;
  line-height: 1.6;
  margin-bottom: 20rpx;
}

.sheet-distance {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: #F3F4F6;
  border-radius: 50rpx;
  padding: 12rpx 28rpx;
  margin-bottom: 30rpx;
}

.distance-icon {
  font-size: 24rpx;
}

.distance-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  font-weight: 600;
}

.collect-btn {
  width: 100%;
  font-size: 32rpx;
}

/* ===== 收集成功模态框 ===== */
.success-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
}

.success-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.success-content {
  position: relative;
  background: white;
  border-radius: 30rpx;
  padding: 50rpx 40rpx;
  width: 80%;
  max-width: 600rpx;
  border: 6rpx solid var(--border-color);
  box-shadow: 0 16rpx 60rpx rgba(0, 0, 0, 0.2);
  text-align: center;
}

.success-celebration {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.success-title {
  font-size: 36rpx;
  font-weight: 900;
  color: var(--text-primary);
  margin-bottom: 24rpx;
}

.success-item-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  border: 6rpx solid var(--border-color);
  margin: 0 auto 20rpx;
}

.success-item-name {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.success-rarity {
  font-size: 26rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.success-coins {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  background: #FEF3C7;
  border-radius: 50rpx;
  padding: 12rpx 28rpx;
  margin: 0 auto 30rpx;
  border: 4rpx solid #F59E0B;
  display: inline-flex;
}

.coins-icon {
  font-size: 28rpx;
}

.coins-text {
  font-size: 28rpx;
  font-weight: bold;
  color: #92400E;
}

.success-btn {
  width: 100%;
  margin-top: 20rpx;
}

/* ===== 疯狂点击收集弹窗 ===== */
.collecting-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
}

.collecting-backdrop {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: radial-gradient(circle at center, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.95) 100%);
}

.collecting-content {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

/* 进度条容器 - 垂直填充样式 */
.progress-ring-container {
  position: relative;
  width: 400rpx;
  height: 400rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
  border: 8rpx solid rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  box-shadow: 0 0 60rpx rgba(0, 0, 0, 0.5), inset 0 0 40rpx rgba(0, 0, 0, 0.3);
}

.progress-track {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100%;
  overflow: hidden;
}

.progress-fill {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  transition: height 0.08s ease-out;
  background: linear-gradient(to top, rgba(255,255,255,0.3) 0%, transparent 100%);
}

/* 中心内容 */
.progress-center {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.treasure-icon-wrap {
  width: 160rpx;
  height: 160rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 8rpx solid rgba(255, 255, 255, 0.5);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.4);
}

.treasure-icon {
  width: 90rpx;
  height: 90rpx;
}

/* 宝物跳动动画 */
.treasure-bouncing {
  animation: treasure-bounce 0.15s ease-out;
}

@keyframes treasure-bounce {
  0% { transform: scale(1); }
  50% { transform: scale(1.25) rotate(10deg); }
  100% { transform: scale(1); }
}

/* 环形摇晃 */
.ring-shaking {
  animation: ring-shake 0.1s ease-in-out;
}

@keyframes ring-shake {
  0%, 100% { transform: rotate(0deg); }
  25% { transform: rotate(-3deg); }
  75% { transform: rotate(3deg); }
}

/* 连击提示 */
.combo-container {
  margin-top: 40rpx;
  animation: combo-pop 0.3s ease-out;
}

.combo-text {
  font-size: 48rpx;
  font-weight: 900;
  color: #FCD34D;
  text-shadow: 0 4rpx 20rpx rgba(252, 211, 77, 0.6), 0 0 40rpx rgba(252, 211, 77, 0.4);
}

@keyframes combo-pop {
  0% { transform: scale(0.5); opacity: 0; }
  50% { transform: scale(1.2); }
  100% { transform: scale(1); opacity: 1; }
}

/* 点击次数显示 */
.collecting-taps-count {
  margin-top: 30rpx;
}

.taps-number {
  font-size: 72rpx;
  font-weight: 900;
  color: white;
  text-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.5);
}

/* 稀有度发光效果 */
.animate-common-glow {
  animation: common-glow 1.5s ease-in-out infinite;
}

.animate-rare-glow {
  animation: rare-glow 1.2s ease-in-out infinite;
}

.animate-epic-glow {
  animation: epic-glow 1s ease-in-out infinite;
}

.animate-legendary-glow {
  animation: legendary-glow 0.8s ease-in-out infinite;
}

@keyframes common-glow {
  0%, 100% { box-shadow: 0 0 20rpx rgba(107, 114, 128, 0.4); }
  50% { box-shadow: 0 0 40rpx rgba(107, 114, 128, 0.7); }
}

@keyframes rare-glow {
  0%, 100% { box-shadow: 0 0 30rpx rgba(14, 165, 233, 0.5), 0 0 60rpx rgba(14, 165, 233, 0.3); }
  50% { box-shadow: 0 0 50rpx rgba(14, 165, 233, 0.8), 0 0 100rpx rgba(14, 165, 233, 0.5); }
}

@keyframes epic-glow {
  0%, 100% { box-shadow: 0 0 40rpx rgba(139, 92, 246, 0.6), 0 0 80rpx rgba(139, 92, 246, 0.4); }
  50% { box-shadow: 0 0 70rpx rgba(139, 92, 246, 0.9), 0 0 140rpx rgba(139, 92, 246, 0.6); }
}

@keyframes legendary-glow {
  0%, 100% { box-shadow: 0 0 50rpx rgba(245, 158, 11, 0.7), 0 0 100rpx rgba(245, 158, 11, 0.5), 0 0 150rpx rgba(245, 158, 11, 0.3); }
  50% { box-shadow: 0 0 80rpx rgba(245, 158, 11, 1), 0 0 160rpx rgba(245, 158, 11, 0.7), 0 0 240rpx rgba(245, 158, 11, 0.4); }
}

/* 稀有度标签 */
.collecting-rarity-label {
  margin-top: 24rpx;
  font-size: 32rpx;
  font-weight: bold;
  padding: 14rpx 40rpx;
  border-radius: 50rpx;
  background: rgba(255, 255, 255, 0.15);
  color: white;
  backdrop-filter: blur(10rpx);
  border: 2rpx solid rgba(255, 255, 255, 0.3);
}

/* 浮动点击效果 */
.tap-effects {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  z-index: 201;
}

.tap-effect-item {
  position: absolute;
  animation: tap-burst 0.5s ease-out forwards;
  pointer-events: none;
}

.tap-float-text {
  font-size: 42rpx;
  font-weight: 900;
  text-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.5);
}

@keyframes tap-burst {
  0% {
    opacity: 1;
    transform: scale(0.5) translateY(0);
  }
  30% {
    opacity: 1;
    transform: scale(1.5) translateY(-20rpx);
  }
  100% {
    opacity: 0;
    transform: scale(1) translateY(-100rpx);
  }
}

/* 收集完成时的爆发动画 */
.collect-complete {
  animation: collect-complete 0.5s ease-out forwards;
}

@keyframes collect-complete {
  0% { transform: scale(1); }
  30% { transform: scale(1.3); }
  60% { transform: scale(0.9); }
  100% { transform: scale(1); }
}
