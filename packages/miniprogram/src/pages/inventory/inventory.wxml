<view class="container">
  <!-- 顶部栏 -->
  <view class="header">
    <view class="header-left">
      <image class="icon title-icon" src="/images/icons/backpack.svg" mode="aspectFit" />
      <text class="title-text">我的收藏</text>
    </view>
    <view class="header-right">
      <view class="balance-pill" wx:if="{{ isLoggedIn }}">
        <image class="icon-sm balance-icon" src="/images/icons/coins.svg" mode="aspectFit" />
        <text class="balance-value">{{ balance }}</text>
      </view>
      <view class="selection-toggle {{ selectionMode ? 'active' : '' }}" bindtap="toggleSelectionMode" wx:if="{{ isLoggedIn }}">
        <image class="icon" src="/images/icons/tag.svg" mode="aspectFit" />
      </view>
    </view>
  </view>

  <!-- 未登录状态 -->
  <view class="empty-state" wx:if="{{ !isLoggedIn }}">
    <view class="empty-icon-circle">
      <image class="icon-xl" src="/images/icons/lock.svg" mode="aspectFit" />
    </view>
    <view class="empty-state-text">登录后查看背包</view>
    <view class="empty-state-subtext">登录后可查看和管理您的收藏</view>
    <button class="cartoon-btn" bindtap="goToLogin" style="margin-top: 40rpx;">立即登录</button>
  </view>

  <!-- 已登录状态 -->
  <block wx:elif="{{ !loading }}">
    <!-- 统计栏 -->
    <view class="stats-bar">
      <view class="stat-item">
        <text class="stat-number">{{ totalItems }}</text>
        <text class="stat-label">总数</text>
      </view>
      <view class="stat-item">
        <text class="stat-number">{{ uniqueItems }}</text>
        <text class="stat-label">种类</text>
      </view>
      <view class="stat-item" wx:if="{{ commonCount > 0 }}">
        <text class="stat-number rarity-common">{{ commonCount }}</text>
        <text class="stat-label">普通</text>
      </view>
      <view class="stat-item" wx:if="{{ rareCount > 0 }}">
        <text class="stat-number rarity-rare">{{ rareCount }}</text>
        <text class="stat-label">稀有</text>
      </view>
      <view class="stat-item" wx:if="{{ epicCount > 0 }}">
        <text class="stat-number rarity-epic">{{ epicCount }}</text>
        <text class="stat-label">史诗</text>
      </view>
      <view class="stat-item" wx:if="{{ legendaryCount > 0 }}">
        <text class="stat-number rarity-legendary">{{ legendaryCount }}</text>
        <text class="stat-label">传说</text>
      </view>
    </view>

    <!-- 批量操作栏 -->
    <view class="batch-bar" wx:if="{{ selectionMode }}">
      <view class="batch-left">
        <text class="batch-count">{{ selectedCount }} 个已选</text>
        <text class="batch-value">= {{ selectedTotalValue }} 金币</text>
      </view>
      <view class="batch-right">
        <view class="batch-btn-selectall" bindtap="selectAll">全选</view>
        <view class="batch-btn-sell {{ selectedCount === 0 ? 'disabled' : '' }}" bindtap="handleBatchSell">全部出售</view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{ items.length === 0 }}">
      <view class="empty-icon-circle">
        <image class="icon-xl" src="/images/icons/package.svg" mode="aspectFit" />
      </view>
      <view class="empty-state-text">还没有收集物品</view>
      <view class="empty-state-subtext">去地图探索寻找宝藏吧！</view>
    </view>

    <!-- 物品网格 -->
    <view class="item-grid animate-page-enter" wx:else>
      <view
        class="item-card {{ item.selected ? 'selected' : '' }}"
        wx:for="{{ items }}"
        wx:key="id"
        bindtap="{{ selectionMode ? 'toggleItemSelection' : '' }}"
        data-index="{{ index }}"
      >
        <!-- 选择圆圈 -->
        <view class="select-circle {{ item.selected ? 'checked' : '' }}" wx:if="{{ selectionMode }}">
          <image class="icon-sm" src="/images/icons/check.svg" mode="aspectFit" wx:if="{{ item.selected }}" />
        </view>

        <!-- 物品图标 -->
        <view class="item-icon-wrap {{ item.rarityBgClass }}">
          <image class="icon item-icon-emoji" src="/images/icons/gem.svg" mode="aspectFit" />
        </view>

        <!-- 物品信息 -->
        <view class="item-body">
          <text class="item-name">{{ item.item.name }}</text>
          <text class="item-rarity" style="color: {{ item.rarityColor }};">{{ item.rarityName }}</text>
          <view class="item-poi" wx:if="{{ item.poiName }}">
            <image class="icon-sm poi-icon" src="/images/icons/map-pin.svg" mode="aspectFit" />
            <text class="poi-text">{{ item.poiName }}</text>
          </view>
        </view>

        <!-- 数量徽章 -->
        <view class="quantity-badge">
          <text class="quantity-text">x{{ item.quantity }}</text>
        </view>

        <!-- 价格和出售 -->
        <view class="item-footer" wx:if="{{ !selectionMode }}">
          <view class="item-price">
            <image class="icon-sm price-icon" src="/images/icons/coins.svg" mode="aspectFit" />
            <text class="price-value">{{ item.npcPrice }} 金币</text>
          </view>
          <view class="sell-btn" catchtap="openSellModal" data-index="{{ index }}">
            <view style="display:flex;align-items:center;gap:6rpx;"><image class="icon-sm" src="/images/icons/shopping-cart.svg" mode="aspectFit" /><text>出售</text></view>
          </view>
        </view>
      </view>
    </view>
  </block>

  <!-- 加载中 -->
  <view class="loading-container" wx:if="{{ loading && isLoggedIn }}">
    <view class="cartoon-loader"></view>
  </view>

  <!-- 出售模态框 -->
  <view class="modal-overlay" wx:if="{{ sellModalOpen }}" catchtap="closeSellModal">
    <view class="modal-content animate-bounce-in" catchtap="">
      <view class="modal-header">
        <text class="modal-title">出售给NPC</text>
        <view class="modal-close" bindtap="closeSellModal"><image class="icon-sm" src="/images/icons/x.svg" mode="aspectFit" /></view>
      </view>

      <view class="sell-item-preview" wx:if="{{ sellItemData }}">
        <view class="preview-icon {{ sellItemData.rarityBgClass }}">
          <image class="icon" src="/images/icons/gem.svg" mode="aspectFit" />
        </view>
        <view class="preview-info">
          <text class="preview-name">{{ sellItemData.item.name }}</text>
          <text class="preview-rarity" style="color: {{ sellItemData.rarityColor }};">{{ sellItemData.rarityName }}</text>
          <text class="preview-own">拥有: {{ sellItemData.quantity }}</text>
        </view>
      </view>

      <!-- 数量选择 -->
      <view class="qty-selector">
        <text class="qty-label">数量</text>
        <view class="qty-controls">
          <view class="qty-btn" bindtap="decreaseSellQty">-</view>
          <text class="qty-value">{{ sellQuantity }}</text>
          <view class="qty-btn" bindtap="increaseSellQty">+</view>
        </view>
      </view>

      <!-- 总价 -->
      <view class="sell-total">
        <text class="sell-total-label">您将获得:</text>
        <view class="sell-total-value">
          <image class="icon-sm sell-total-icon" src="/images/icons/coins.svg" mode="aspectFit" />
          <text class="sell-total-number">{{ sellTotalPrice }}</text>
        </view>
      </view>

      <!-- 按钮 -->
      <view class="modal-buttons">
        <view class="modal-btn-cancel" bindtap="closeSellModal">取消</view>
        <view class="modal-btn-confirm {{ sellLoading ? 'loading' : '' }}" bindtap="confirmSell">
          <view wx:if="{{ !sellLoading }}" style="display:flex;align-items:center;justify-content:center;gap:6rpx;"><image class="icon-sm" src="/images/icons/check.svg" mode="aspectFit" /><text>出售</text></view>
          <text wx:else>出售中...</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 成功模态框 -->
  <view class="modal-overlay" wx:if="{{ successModalOpen }}" catchtap="closeSuccessModal">
    <view class="modal-content animate-bounce-in success-modal" catchtap="">
      <view class="success-icon-circle">
        <image class="icon-xl" src="/images/icons/coins.svg" mode="aspectFit" />
      </view>
      <text class="success-title">已出售！</text>
      <text class="success-msg">{{ successMessage }}</text>
      <text class="success-coins">+{{ successCoins }} 金币</text>
      <view class="modal-btn-confirm" bindtap="closeSuccessModal">确定</view>
    </view>
  </view>
</view>
