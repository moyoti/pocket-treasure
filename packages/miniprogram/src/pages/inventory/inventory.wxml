<view class="container">
  <!-- 顶部栏 -->
  <view class="header">
    <view class="title">🎒 我的背包</view>
    <view class="balance" wx:if="{{ isLoggedIn }}">
      <text class="balance-icon">💰</text>
      <text class="balance-value">{{ balance }}</text>
    </view>
  </view>
  
  <!-- 未登录状态 -->
  <view class="empty-state" wx:if="{{ !isLoggedIn }}">
    <view class="empty-state-icon">🔐</view>
    <view class="empty-state-text">登录后查看背包</view>
    <view class="empty-state-subtext">登录后可查看和管理您的收藏</view>
    <button class="cartoon-btn" bindtap="goToLogin" style="margin-top: 40rpx;">立即登录</button>
  </view>
  
  <!-- 已登录状态 -->
  <block wx:else>
    <!-- 操作栏 -->
    <view class="action-bar">
      <view class="item-count">共 {{ items.length }} 种物品</view>
      <view class="action-btns">
        <button class="action-btn" bindtap="toggleSelectionMode">
          {{ selectionMode ? '取消' : '批量出售' }}
        </button>
        <button class="action-btn primary" wx:if="{{ selectionMode }}" bindtap="selectAll">全选</button>
      </view>
    </view>
    
    <!-- 批量操作栏 -->
    <view class="batch-bar" wx:if="{{ selectionMode }}">
      <text class="batch-info">已选 {{ selectedItems.size }} 个</text>
      <button class="cartoon-btn batch-sell-btn" bindtap="handleBatchSell" disabled="{{ selectedItems.size === 0 }}">
        批量出售
      </button>
    </view>
    
    <!-- 加载中 -->
    <view class="loading-container" wx:if="{{ loading }}">
      <view class="loading-spinner"></view>
    </view>
    
    <!-- 空状态 -->
    <view class="empty-state" wx:elif="{{ items.length === 0 }}">
      <view class="empty-state-icon">📦</view>
      <view class="empty-state-text">背包空空如也</view>
      <view class="empty-state-subtext">去地图探索收集宝藏吧！</view>
    </view>
    
    <!-- 物品列表 -->
    <view class="item-list" wx:else>
      <view 
        class="item-card {{ selectedItems.has(item.id) ? 'selected' : '' }}"
        wx:for="{{ items }}"
        wx:key="id"
        bindtap="{{ selectionMode ? 'toggleItemSelection' : '' }}"
        data-id="{{ item.id }}"
      >
        <view class="item-checkbox" wx:if="{{ selectionMode }}">
          <view class="checkbox {{ selectedItems.has(item.id) ? 'checked' : '' }}">
            <text wx:if="{{ selectedItems.has(item.id) }}">✓</text>
          </view>
        </view>
        
        <view class="item-icon rarity-bg-{{ item.item.rarity }}">
          <text class="icon-emoji">💎</text>
        </view>
        
        <view class="item-info">
          <view class="item-name">{{ item.item.name }}</view>
          <view class="item-rarity rarity-{{ item.item.rarity }}">{{ item.item.rarity === 'common' ? '普通' : item.item.rarity === 'rare' ? '稀有' : item.item.rarity === 'epic' ? '史诗' : '传说' }}</view>
          <view class="item-desc">{{ item.item.description }}</view>
        </view>
        
        <view class="item-right">
          <view class="item-quantity">x{{ item.quantity }}</view>
          <view class="item-price">💰 {{ item.item.value || 10 }}</view>
          <button 
            class="sell-btn" 
            wx:if="{{ !selectionMode }}"
            catchtap="handleSellItem"
            data-item="{{ item }}"
          >出售</button>
        </view>
      </view>
    </view>
  </block>
</view>
