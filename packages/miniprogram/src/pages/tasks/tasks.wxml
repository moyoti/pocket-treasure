<view class="container">
  <!-- 顶部栏 -->
  <view class="header">
    <view class="header-center">
      <image class="icon-lg title-icon" src="/images/icons/clipboard-list.svg" mode="aspectFit" />
      <text class="title-text">每日任务</text>
    </view>
  </view>

  <!-- 成功提示 -->
  <view class="success-toast animate-slide-in-down" wx:if="{{ showSuccess }}">
    <image class="icon-sm" src="/images/icons/check.svg" mode="aspectFit" />
    <text class="toast-text">任务奖励领取成功!</text>
    <view class="toast-coin">
      <image class="icon-sm" src="/images/icons/coins.svg" mode="aspectFit" />
      <text> +{{ successRewardCoins }}</text>
    </view>
    <view class="toast-exp">
      <image class="icon-sm" src="/images/icons/star.svg" mode="aspectFit" />
      <text> +{{ successRewardExp }}</text>
    </view>
  </view>

  <!-- 加载中 -->
  <view class="loading-container" wx:if="{{ loading }}">
    <view class="cartoon-loader"></view>
  </view>

  <block wx:else>
    <!-- 进度统计卡片 -->
    <view class="stats-card">
      <view class="stats-left">
        <text class="stats-label">今日进度</text>
        <text class="stats-value">{{ todayCompleted }} / {{ todayTotal }}</text>
      </view>
      <view class="stats-right">
        <view class="stats-percent-circle">
          <text class="stats-percent">{{ progressPercent }}%</text>
        </view>
      </view>
    </view>

    <!-- 进度条 -->
    <view class="progress-bar-wrap">
      <view class="progress-bar-bg">
        <view class="progress-bar-fill" style="width: {{ progressPercent }}%;"></view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{ tasks.length === 0 }}">
      <view class="empty-icon-circle">
        <image class="icon-xl" src="/images/icons/clipboard-list.svg" mode="aspectFit" />
      </view>
      <view class="empty-state-text">暂无每日任务</view>
      <view class="empty-state-subtext">明天再来查看新任务</view>
    </view>

    <!-- 任务列表 -->
    <view class="task-list animate-page-enter" wx:else>
      <view
        class="task-card {{ item.canClaim ? 'claimable' : '' }} {{ item.isClaimed ? 'claimed' : '' }}"
        wx:for="{{ tasks }}"
        wx:key="id"
      >
        <!-- 任务头部 -->
        <view class="task-top">
          <view class="task-icon-wrap">
            <image class="icon" src="{{ item.icon || '/images/icons/pin.svg' }}" mode="aspectFit" />
          </view>
          <view class="task-info">
            <text class="task-name">{{ item.name }}</text>
            <text class="task-desc">{{ item.description }}</text>
          </view>
          <view class="task-status {{ item.statusClass }}">
            <text>{{ item.statusText }}</text>
          </view>
        </view>

        <!-- 进度条 -->
        <view class="task-progress">
          <view class="task-progress-bar">
            <view class="task-progress-fill {{ item.isClaimed ? 'completed' : '' }}" style="width: {{ item.progressPct }}%;"></view>
          </view>
          <text class="task-progress-text">{{ item.progressText }}</text>
        </view>

        <!-- 底部：奖励 + 按钮 -->
        <view class="task-bottom">
          <view class="task-rewards">
            <view class="task-reward-coin">
              <image class="icon-sm" src="/images/icons/coins.svg" mode="aspectFit" />
              <text> {{ item.rewardCoins }}</text>
            </view>
            <view class="task-reward-exp">
              <image class="icon-sm" src="/images/icons/star.svg" mode="aspectFit" />
              <text> {{ item.rewardExp }}</text>
            </view>
          </view>

          <view
            class="task-claim-btn {{ item.isClaimed ? 'is-claimed' : '' }} {{ !item.canClaim && !item.isClaimed ? 'is-disabled' : '' }}"
            bindtap="handleClaim"
            data-id="{{ item.id }}"
          >
            <text wx:if="{{ item.isClaimed }}">已领取</text>
            <text wx:elif="{{ item.canClaim && claimingId !== item.id }}">领取奖励</text>
            <text wx:elif="{{ claimingId === item.id }}">领取中...</text>
            <text wx:else>进行中</text>
          </view>
        </view>
      </view>
    </view>
  </block>
</view>
