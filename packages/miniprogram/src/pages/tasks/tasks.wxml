<view class="container">
  <!-- 标题 -->
  <view class="header">
    <view class="title">📋 每日任务</view>
  </view>
  
  <!-- 进度统计 -->
  <view class="stats-card" wx:if="{{ stats }}">
    <view class="stats-info">
      <view class="stats-label">今日进度</view>
      <view class="stats-value">{{ stats.todayCompleted }} / {{ stats.todayTotal }}</view>
    </view>
    <view class="stats-bar">
      <view class="stats-fill" style="width: {{ (stats.todayCompleted / stats.todayTotal) * 100 }}%"></view>
    </view>
  </view>
  
  <!-- 加载中 -->
  <view class="loading-container" wx:if="{{ loading }}">
    <view class="loading-spinner"></view>
  </view>
  
  <!-- 空状态 -->
  <view class="empty-state" wx:elif="{{ tasks.length === 0 }}">
    <view class="empty-state-icon">📋</view>
    <view class="empty-state-text">暂无每日任务</view>
    <view class="empty-state-subtext">明天再来查看新任务</view>
  </view>
  
  <!-- 任务列表 -->
  <view class="task-list" wx:else>
    <view class="task-card" wx:for="{{ tasks }}" wx:key="id">
      <view class="task-header">
        <view class="task-icon">{{ item.icon || '📌' }}</view>
        <view class="task-info">
          <view class="task-name">{{ item.name }}</view>
          <view class="task-desc">{{ item.description }}</view>
        </view>
      </view>
      
      <view class="task-progress">
        <view class="progress-bar">
          <view class="progress-fill" style="width: {{ (item.progress / item.requirement) * 100 }}%"></view>
        </view>
        <view class="progress-text">{{ item.progress }} / {{ item.requirement }}</view>
      </view>
      
      <view class="task-footer">
        <view class="task-rewards">
          <text>💰 {{ item.rewards?.coins || 10 }}</text>
          <text>⭐ {{ item.rewards?.experience || 5 }}</text>
        </view>
        
        <button 
          class="claim-btn {{ item.status === 'claimed' ? 'claimed' : '' }}"
          bindtap="handleClaim"
          data-id="{{ item.id }}"
          disabled="{{ item.status !== 'completed' }}"
        >
          {{ item.status === 'claimed' ? '已领取' : item.status === 'completed' ? '领取奖励' : '进行中' }}
        </button>
      </view>
    </view>
  </view>
</view>
