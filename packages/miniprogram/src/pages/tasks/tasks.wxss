.container {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

.header {
  background: white;
  padding: 30rpx;
  border-bottom: 6rpx solid var(--border-color);
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: var(--text-primary);
}

.stats-card {
  background: white;
  padding: 30rpx;
  margin: 20rpx;
  border-radius: 20rpx;
  border: 6rpx solid var(--border-color);
}

.stats-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.stats-label {
  font-size: 26rpx;
  color: var(--text-muted);
}

.stats-value {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-primary);
}

.stats-bar {
  height: 20rpx;
  background: #E5E7EB;
  border-radius: 10rpx;
  overflow: hidden;
}

.stats-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  border-radius: 10rpx;
}

.task-list {
  padding: 20rpx;
}

.task-card {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  border: 6rpx solid var(--border-color);
}

.task-header {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.task-icon {
  width: 60rpx;
  height: 60rpx;
  background: #FEF3C7;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  border: 4rpx solid #F59E0B;
}

.task-info {
  flex: 1;
}

.task-name {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--text-primary);
}

.task-desc {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-top: 8rpx;
}

.task-progress {
  margin-top: 20rpx;
}

.progress-bar {
  height: 12rpx;
  background: #E5E7EB;
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #6BCB77 0%, #5AB669 100%);
  border-radius: 6rpx;
}

.progress-text {
  font-size: 22rpx;
  color: var(--text-muted);
  margin-top: 8rpx;
  text-align: right;
}

.task-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 4rpx solid #F3F4F6;
}

.task-rewards {
  display: flex;
  gap: 20rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.claim-btn {
  padding: 12rpx 30rpx;
  background: var(--primary-color);
  border-radius: 30rpx;
  font-size: 24rpx;
  font-weight: bold;
  color: var(--text-primary);
  border: 4rpx solid var(--border-color);
}

.claim-btn.claimed {
  background: #E5E7EB;
  color: var(--text-muted);
}

.claim-btn[disabled] {
  opacity: 0.6;
}
