/* ===== Icon Sizes ===== */
.icon {
  width: 36rpx;
  height: 36rpx;
  vertical-align: middle;
}
.icon-sm {
  width: 28rpx;
  height: 28rpx;
}
.icon-lg {
  width: 48rpx;
  height: 48rpx;
}
.icon-xl {
  width: 64rpx;
  height: 64rpx;
}

.container {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* ===== Header ===== */
.header {
  background: white;
  padding: 24rpx 30rpx;
  border-bottom: 6rpx solid var(--border-color);
  position: sticky;
  top: 0;
  z-index: 40;
}

.header-center {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.title-icon {
  font-size: 40rpx;
}

.title-text {
  font-size: 36rpx;
  font-weight: 900;
  color: var(--text-primary);
}

/* ===== Success Toast ===== */
.success-toast {
  position: fixed;
  top: 120rpx;
  left: 50%;
  transform: translateX(-50%);
  z-index: 50;
  background: #D1FAE5;
  border: 6rpx solid #10B981;
  border-radius: 24rpx;
  padding: 20rpx 32rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
  white-space: nowrap;
}

.toast-icon {
  font-size: 28rpx;
}

.toast-text {
  font-size: 26rpx;
  font-weight: 700;
  color: #065F46;
}

.toast-coin {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #92400E;
}

.toast-exp {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #7C3AED;
}

/* ===== Stats Card ===== */
.stats-card {
  background: white;
  margin: 20rpx;
  border-radius: 24rpx;
  border: 6rpx solid var(--border-color);
  padding: 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.stats-left {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.stats-label {
  font-size: 24rpx;
  color: var(--text-muted);
  font-weight: 600;
}

.stats-value {
  font-size: 44rpx;
  font-weight: 900;
  color: var(--text-primary);
}

.stats-right {
  display: flex;
  align-items: center;
}

.stats-percent-circle {
  width: 90rpx;
  height: 90rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 6rpx solid var(--border-color);
}

.stats-percent {
  font-size: 24rpx;
  font-weight: 900;
  color: var(--text-primary);
}

/* ===== Progress Bar ===== */
.progress-bar-wrap {
  padding: 0 20rpx 20rpx;
}

.progress-bar-bg {
  height: 20rpx;
  background: #E5E7EB;
  border-radius: 10rpx;
  overflow: hidden;
  border: 4rpx solid #D1D5DB;
}

.progress-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  border-radius: 10rpx;
  transition: width 0.5s ease;
}

/* ===== Empty State ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 40rpx;
}

.empty-icon-circle {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: #F3F4F6;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 8rpx solid #D1D5DB;
  margin-bottom: 24rpx;
}

.empty-icon-text {
  font-size: 64rpx;
}

.empty-state-text {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-secondary);
}

.empty-state-subtext {
  font-size: 26rpx;
  color: var(--text-muted);
  margin-top: 12rpx;
}

/* ===== Task List ===== */
.task-list {
  padding: 0 20rpx;
}

.task-card {
  background: white;
  border-radius: 24rpx;
  border: 6rpx solid var(--border-color);
  padding: 28rpx;
  margin-bottom: 20rpx;
}

/* Claimable glow */
.task-card.claimable {
  animation: task-glow 2s ease-in-out infinite;
}

@keyframes task-glow {
  0%, 100% { box-shadow: 0 0 0 0 rgba(255, 217, 61, 0); }
  50% { box-shadow: 0 0 16rpx 6rpx rgba(255, 217, 61, 0.35); }
}

.task-card.claimed {
  opacity: 0.7;
}

/* Task top */
.task-top {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.task-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  background: #FEF3C7;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid #F59E0B;
  flex-shrink: 0;
}

.task-icon {
  font-size: 36rpx;
}

.task-info {
  flex: 1;
  min-width: 0;
}

.task-name {
  display: block;
  font-size: 28rpx;
  font-weight: 900;
  color: var(--text-primary);
}

.task-desc {
  display: block;
  font-size: 24rpx;
  color: var(--text-muted);
  margin-top: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.task-status {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.task-status.status-progress {
  background: #DBEAFE;
  color: #1E40AF;
}

.task-status.status-completed {
  background: #FEF3C7;
  color: #92400E;
}

.task-status.status-claimed {
  background: #D1FAE5;
  color: #059669;
}

/* Task progress */
.task-progress {
  margin-top: 20rpx;
}

.task-progress-bar {
  height: 16rpx;
  background: #E5E7EB;
  border-radius: 8rpx;
  overflow: hidden;
}

.task-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #6BCB77 0%, #5AB669 100%);
  border-radius: 8rpx;
  transition: width 0.5s ease;
}

.task-progress-fill.completed {
  background: linear-gradient(90deg, #10B981 0%, #059669 100%);
}

.task-progress-text {
  display: block;
  font-size: 22rpx;
  color: var(--text-muted);
  text-align: right;
  margin-top: 6rpx;
}

/* Task bottom */
.task-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 4rpx solid #F3F4F6;
}

.task-rewards {
  display: flex;
  gap: 20rpx;
}

.task-reward-coin {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #92400E;
}

.task-reward-exp {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #7C3AED;
}

.task-claim-btn {
  padding: 14rpx 32rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: var(--text-primary);
  background: linear-gradient(180deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  border: 4rpx solid var(--border-color);
}

.task-claim-btn.is-claimed {
  background: #E5E7EB;
  color: var(--text-muted);
  border-color: #D1D5DB;
}

.task-claim-btn.is-disabled {
  opacity: 0.5;
}

/* Loading */
.loading-container {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}
