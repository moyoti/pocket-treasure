/* ===== Icon Sizes ===== */
.icon {
  width: 36rpx;
  height: 36rpx;
  vertical-align: middle;
}
.icon-sm {
  width: 28rpx;
  height: 28rpx;
}
.icon-lg {
  width: 48rpx;
  height: 48rpx;
}
.icon-xl {
  width: 64rpx;
  height: 64rpx;
}

.reward-inner {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.ach-claimed-inner {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.container {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* ===== Header ===== */
.header {
  background: white;
  padding: 24rpx 30rpx;
  border-bottom: 6rpx solid var(--border-color);
  position: sticky;
  top: 0;
  z-index: 40;
}

.header-center {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.title-icon {
  font-size: 40rpx;
}

.title-text {
  font-size: 36rpx;
  font-weight: 900;
  color: var(--text-primary);
}

/* ===== Success Toast ===== */
.success-toast {
  position: fixed;
  top: 120rpx;
  left: 50%;
  transform: translateX(-50%);
  z-index: 50;
  background: #D1FAE5;
  border: 6rpx solid #10B981;
  border-radius: 24rpx;
  padding: 20rpx 32rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
  white-space: nowrap;
}

.toast-icon {
  font-size: 28rpx;
}

.toast-text {
  font-size: 26rpx;
  font-weight: 700;
  color: #065F46;
}

.toast-coin {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #92400E;
}

.toast-exp {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #7C3AED;
}

/* ===== Stats Card ===== */
.stats-card {
  background: white;
  margin: 20rpx;
  border-radius: 24rpx;
  border: 6rpx solid var(--border-color);
  padding: 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.stats-left {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.stats-label {
  font-size: 24rpx;
  color: var(--text-muted);
  font-weight: 600;
}

.stats-value {
  font-size: 44rpx;
  font-weight: 900;
  color: var(--text-primary);
}

.stats-claim-hint {
  font-size: 24rpx;
  font-weight: 700;
  color: #92400E;
}

.stats-badge {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #8B5CF6 0%, #7C3AED 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 8rpx solid white;
  box-shadow: 0 8rpx 24rpx rgba(139, 92, 246, 0.3);
}

.stats-badge-icon {
  font-size: 48rpx;
}

/* ===== Progress Bar ===== */
.progress-bar-wrap {
  padding: 0 20rpx 20rpx;
}

.progress-bar-bg {
  height: 20rpx;
  background: #E5E7EB;
  border-radius: 10rpx;
  overflow: hidden;
  border: 4rpx solid #D1D5DB;
}

.progress-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #8B5CF6 0%, #A78BFA 100%);
  border-radius: 10rpx;
  transition: width 0.5s ease;
}

/* ===== Empty State ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 40rpx;
}

.empty-icon-circle {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: #F3F4F6;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 8rpx solid #D1D5DB;
  margin-bottom: 24rpx;
}

.empty-icon-text {
  font-size: 64rpx;
}

.empty-state-text {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-secondary);
}

.empty-state-subtext {
  font-size: 26rpx;
  color: var(--text-muted);
  margin-top: 12rpx;
}

/* ===== Achievement List ===== */
.achievement-list {
  padding: 0 20rpx;
}

.achievement-card {
  background: white;
  border-radius: 24rpx;
  border: 6rpx solid var(--border-color);
  overflow: hidden;
  margin-bottom: 20rpx;
}

/* Claimable pulse glow */
.achievement-card.claimable {
  animation: claim-glow 2s ease-in-out infinite;
}

@keyframes claim-glow {
  0%, 100% { box-shadow: 0 0 0 0 rgba(255, 217, 61, 0); }
  50% { box-shadow: 0 0 20rpx 8rpx rgba(255, 217, 61, 0.4); }
}

/* Achievement header */
.ach-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx;
}

.ach-icon-circle {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: white;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid rgba(0, 0, 0, 0.15);
  flex-shrink: 0;
}

.ach-icon {
  font-size: 36rpx;
}

.ach-header-info {
  flex: 1;
  min-width: 0;
}

.ach-name {
  display: block;
  font-size: 28rpx;
  font-weight: 900;
  color: var(--text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ach-type-badge {
  display: inline-block;
  margin-top: 6rpx;
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.6);
  font-size: 20rpx;
  font-weight: 700;
  color: var(--text-secondary);
}

.ach-claim-btn {
  padding: 14rpx 28rpx;
  border-radius: 30rpx;
  background: linear-gradient(180deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  border: 4rpx solid var(--border-color);
  font-size: 24rpx;
  font-weight: 700;
  color: var(--text-primary);
  flex-shrink: 0;
}

.ach-claimed-badge {
  padding: 14rpx 28rpx;
  border-radius: 30rpx;
  background: #D1FAE5;
  font-size: 24rpx;
  font-weight: 700;
  color: #059669;
  flex-shrink: 0;
}

/* Achievement body */
.ach-body {
  padding: 20rpx 24rpx 24rpx;
}

.ach-desc {
  display: block;
  font-size: 24rpx;
  color: var(--text-muted);
  margin-bottom: 16rpx;
}

/* Progress */
.ach-progress {
  margin-bottom: 16rpx;
}

.ach-progress-bar {
  height: 16rpx;
  background: #E5E7EB;
  border-radius: 8rpx;
  overflow: hidden;
}

.ach-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #8B5CF6 0%, #A78BFA 100%);
  border-radius: 8rpx;
  transition: width 0.5s ease;
}

.ach-progress-text {
  display: block;
  font-size: 22rpx;
  color: var(--text-muted);
  text-align: right;
  margin-top: 6rpx;
}

/* Rewards */
.ach-rewards {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
  padding-top: 16rpx;
  border-top: 4rpx solid #F3F4F6;
}

.ach-reward {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--text-secondary);
  background: #F9FAFB;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  border: 2rpx solid #E5E7EB;
}

.ach-reward-title {
  background: #FEF3C7;
  border-color: #FDE68A;
  color: #92400E;
}

/* Loading */
.loading-container {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}
