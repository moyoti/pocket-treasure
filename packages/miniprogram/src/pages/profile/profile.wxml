<view class="container">
  <!-- 未登录状态 -->
  <view class="guest-card" wx:if="{{ !isLoggedIn }}">
    <view class="guest-avatar">👤</view>
    <view class="guest-title">探险家</view>
    <view class="guest-desc">登录后可保存游戏进度</view>
    <button class="cartoon-btn login-btn" bindtap="goToLogin">
      🔐 立即登录
    </button>
  </view>
  
  <!-- 已登录状态 -->
  <block wx:else>
    <!-- 用户信息卡片 -->
    <view class="profile-card">
      <view class="avatar">
        <text class="avatar-text">{{ userInfo.username ? userInfo.username[0].toUpperCase() : '探' }}</text>
      </view>
      <view class="username">{{ userInfo.username || '探险家' }}</view>
      <view class="email">{{ userInfo.email || '' }}</view>
      
      <view class="balance-badge">
        <text class="balance-icon">💰</text>
        <text class="balance-value">{{ balance }}</text>
        <text class="balance-unit">金币</text>
      </view>
    </view>
    
    <!-- 统计信息 -->
    <view class="stats-card" wx:if="{{ stats }}">
      <view class="stat-item">
        <view class="stat-value">{{ stats.collection?.totalItems || 0 }}</view>
        <view class="stat-label">收集物品</view>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <view class="stat-value">{{ stats.achievements?.completed || 0 }}</view>
        <view class="stat-label">成就</view>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <view class="stat-value">{{ stats.friends || 0 }}</view>
        <view class="stat-label">好友</view>
      </view>
    </view>
  </block>
  
  <!-- 菜单列表 -->
  <view class="menu-card">
    <view 
      class="menu-item" 
      wx:for="{{ menuItems }}" 
      wx:key="path"
      bindtap="navigateTo"
      data-path="{{ item.path }}"
    >
      <view class="menu-icon">{{ item.icon }}</view>
      <view class="menu-label">{{ item.label }}</view>
      <view class="menu-arrow">›</view>
    </view>
  </view>
  
  <!-- 退出登录 -->
  <button class="logout-btn" bindtap="handleLogout" wx:if="{{ isLoggedIn }}">退出登录</button>
</view>
