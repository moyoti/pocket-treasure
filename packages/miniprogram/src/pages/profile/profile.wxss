.icon {
  width: 36rpx;
  height: 36rpx;
  vertical-align: middle;
}
.icon-sm {
  width: 28rpx;
  height: 28rpx;
}
.icon-lg {
  width: 48rpx;
  height: 48rpx;
}
.icon-xl {
  width: 64rpx;
  height: 64rpx;
}

.container {
  min-height: 100vh;
  padding: 30rpx;
  padding-bottom: 120rpx;
}

/* 未登录卡片 */
.guest-card {
  background: white;
  border-radius: 30rpx;
  padding: 60rpx;
  text-align: center;
  border: 6rpx solid var(--border-color);
  box-shadow: 0 8rpx 0 rgba(0, 0, 0, 0.1);
}

.guest-avatar {
  width: 140rpx;
  height: 140rpx;
  background: linear-gradient(135deg, #E5E7EB 0%, #D1D5DB 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto;
  font-size: 70rpx;
  border: 6rpx solid var(--border-color);
}

.guest-title {
  font-size: 40rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-top: 30rpx;
}

.guest-desc {
  font-size: 26rpx;
  color: var(--text-muted);
  margin-top: 12rpx;
}

.login-btn {
  margin-top: 40rpx;
  padding: 24rpx 60rpx;
}

/* 用户信息卡片 */
.profile-card {
  background: white;
  border-radius: 30rpx;
  padding: 50rpx;
  text-align: center;
  border: 6rpx solid var(--border-color);
  box-shadow: 0 8rpx 0 rgba(0, 0, 0, 0.1);
}

.avatar {
  width: 140rpx;
  height: 140rpx;
  background: linear-gradient(135deg, #FDE047 0%, #FB923C 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto;
  border: 6rpx solid var(--border-color);
  box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.15);
}

.avatar-text {
  font-size: 64rpx;
  font-weight: bold;
  color: white;
}

.username {
  font-size: 42rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-top: 24rpx;
}

.email {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-top: 8rpx;
}

.balance-badge {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  background: linear-gradient(135deg, #FEF3C7 0%, #FCD34D 100%);
  padding: 16rpx 40rpx;
  border-radius: 50rpx;
  margin-top: 30rpx;
  border: 4rpx solid #F59E0B;
}

.balance-icon {
  font-size: 32rpx;
}

.balance-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #92400E;
}

.balance-unit {
  font-size: 24rpx;
  color: #92400E;
}

/* 统计行 */
.stats-row {
  display: flex;
  background: white;
  border-radius: 24rpx;
  padding: 30rpx 20rpx;
  margin-top: 24rpx;
  border: 6rpx solid var(--border-color);
  box-shadow: 0 8rpx 0 rgba(0, 0, 0, 0.1);
}

.stats-item {
  flex: 1;
  text-align: center;
  position: relative;
}

.stats-item:not(:last-child)::after {
  content: '';
  position: absolute;
  right: 0;
  top: 10rpx;
  bottom: 10rpx;
  width: 4rpx;
  background: #E5E7EB;
}

.stats-number {
  font-size: 44rpx;
  font-weight: bold;
  color: var(--text-primary);
}

.stats-label {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-top: 8rpx;
}

/* 菜单卡片 */
.menu-card {
  background: white;
  border-radius: 24rpx;
  margin-top: 24rpx;
  border: 6rpx solid var(--border-color);
  box-shadow: 0 8rpx 0 rgba(0, 0, 0, 0.1);
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 30rpx;
  border-bottom: 4rpx solid #F3F4F6;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon-wrapper {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.menu-icon-text {
  font-size: 36rpx;
}

.menu-label {
  flex: 1;
  font-size: 30rpx;
  font-weight: bold;
  color: var(--text-primary);
}

.menu-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.menu-extra {
  font-size: 22rpx;
  color: var(--text-muted);
  background: #F3F4F6;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.menu-arrow-icon {
  opacity: 0.4;
}

/* 退出按钮 */
.logout-btn {
  width: 100%;
  margin-top: 40rpx;
  background: #FEE2E2;
  color: #DC2626;
  border: 4rpx solid #FCA5A5;
  border-radius: 24rpx;
  padding: 30rpx;
  font-size: 30rpx;
  font-weight: bold;
  text-align: center;
}
