.container {
  min-height: 100vh;
  padding: 30rpx;
  padding-bottom: 120rpx;
}

.guest-card {
  background: white;
  border-radius: 30rpx;
  padding: 60rpx;
  text-align: center;
  border: 6rpx solid var(--border-color);
  box-shadow: 0 8rpx 0 rgba(0, 0, 0, 0.1);
}

.guest-avatar {
  width: 140rpx;
  height: 140rpx;
  background: linear-gradient(135deg, #E5E7EB 0%, #D1D5DB 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto;
  font-size: 70rpx;
  border: 6rpx solid var(--border-color);
}

.guest-title {
  font-size: 40rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-top: 30rpx;
}

.guest-desc {
  font-size: 26rpx;
  color: var(--text-muted);
  margin-top: 12rpx;
}

.login-btn {
  margin-top: 40rpx;
  padding: 24rpx 60rpx;
}

.profile-card {
  background: white;
  border-radius: 30rpx;
  padding: 50rpx;
  text-align: center;
  border: 6rpx solid var(--border-color);
  box-shadow: 0 8rpx 0 rgba(0, 0, 0, 0.1);
}

.avatar {
  width: 140rpx;
  height: 140rpx;
  background: linear-gradient(135deg, var(--primary-color) 0%, #F59E0B 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto;
  border: 6rpx solid var(--border-color);
}

.avatar-text {
  font-size: 60rpx;
  font-weight: bold;
  color: var(--text-primary);
}

.username {
  font-size: 40rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-top: 24rpx;
}

.email {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-top: 8rpx;
}

.balance-badge {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  background: linear-gradient(135deg, #FEF3C7 0%, #FCD34D 100%);
  padding: 16rpx 40rpx;
  border-radius: 50rpx;
  margin-top: 30rpx;
  border: 4rpx solid #F59E0B;
}

.balance-icon {
  font-size: 32rpx;
}

.balance-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #92400E;
}

.balance-unit {
  font-size: 24rpx;
  color: #92400E;
}

.stats-card {
  display: flex;
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-top: 30rpx;
  border: 6rpx solid var(--border-color);
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-value {
  font-size: 40rpx;
  font-weight: bold;
  color: var(--text-primary);
}

.stat-label {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-top: 8rpx;
}

.stat-divider {
  width: 4rpx;
  background: #E5E7EB;
  margin: 0 20rpx;
}

.menu-card {
  background: white;
  border-radius: 20rpx;
  margin-top: 30rpx;
  border: 6rpx solid var(--border-color);
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 4rpx solid #F3F4F6;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.menu-label {
  flex: 1;
  font-size: 30rpx;
  color: var(--text-primary);
}

.menu-arrow {
  font-size: 40rpx;
  color: var(--text-muted);
}

.logout-btn {
  width: 100%;
  margin-top: 40rpx;
  background: #FEE2E2;
  color: #DC2626;
  border: 4rpx solid #EF4444;
  border-radius: 20rpx;
  padding: 30rpx;
  font-size: 30rpx;
  font-weight: bold;
}
