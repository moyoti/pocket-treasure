.btn-inner {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
}

.login-hint-inner {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.modal-title-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.container {
  min-height: 100vh;
  padding-bottom: 120rpx;
}

/* ===== Header ===== */
.header {
  background: white;
  padding: 24rpx 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 6rpx solid var(--border-color);
  position: sticky;
  top: 0;
  z-index: 40;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.title-icon {
  font-size: 40rpx;
}

.title-text {
  font-size: 36rpx;
  font-weight: 900;
  color: var(--text-primary);
}

.balance-pill {
  display: flex;
  align-items: center;
  gap: 10rpx;
  background: linear-gradient(135deg, #FEF3C7 0%, #FDE68A 100%);
  padding: 14rpx 28rpx;
  border-radius: 50rpx;
  border: 6rpx solid #F59E0B;
}

.balance-icon {
  font-size: 28rpx;
}

.balance-value {
  font-size: 28rpx;
  font-weight: 900;
  color: #92400E;
}

.login-hint {
  background: linear-gradient(135deg, #FEF3C7 0%, #FDE68A 100%);
  padding: 14rpx 28rpx;
  border-radius: 50rpx;
  border: 4rpx solid #F59E0B;
  font-size: 24rpx;
  font-weight: 700;
  color: #92400E;
}

/* ===== Pool Selector ===== */
.pool-selector {
  white-space: nowrap;
  padding: 20rpx 30rpx;
  background: white;
}

.pool-tab {
  display: inline-block;
  padding: 16rpx 40rpx;
  background: #F3F4F6;
  border-radius: 40rpx;
  margin-right: 16rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-secondary);
  border: 6rpx solid var(--border-color);
}

.pool-tab.active {
  background: #EDE9FE;
  color: #5B21B6;
  border-color: #8B5CF6;
}

/* ===== Gacha Main ===== */
.gacha-main {
  padding: 30rpx;
}

.gacha-card {
  background: white;
  border-radius: 30rpx;
  padding: 40rpx;
  border: 6rpx solid var(--border-color);
  text-align: center;
  box-shadow: 0 8rpx 0 rgba(0, 0, 0, 0.1);
}

/* Gift animation */
.gacha-gift-wrap {
  margin-bottom: 24rpx;
}

.gacha-gift-img {
  width: 120rpx;
  height: 120rpx;
  display: inline-block;
  animation: float 3s ease-in-out infinite;
}

.gacha-gift-wrap.pulling .gacha-gift-img {
  animation: gacha-spin 0.5s ease-in-out infinite;
}


@keyframes gacha-spin {
  0% { transform: rotate(0deg) scale(1); }
  25% { transform: rotate(15deg) scale(1.1); }
  50% { transform: rotate(0deg) scale(1); }
  75% { transform: rotate(-15deg) scale(1.1); }
  100% { transform: rotate(0deg) scale(1); }
}

.gacha-pool-name {
  display: block;
  font-size: 40rpx;
  font-weight: 900;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.gacha-pool-desc {
  display: block;
  font-size: 26rpx;
  color: var(--text-muted);
  margin-bottom: 30rpx;
}

/* ===== Pity Section ===== */
.pity-section {
  background: #F5F3FF;
  border-radius: 20rpx;
  padding: 24rpx;
  border: 4rpx solid #DDD6FE;
  margin-bottom: 30rpx;
}

.pity-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.pity-label {
  font-size: 26rpx;
  font-weight: 700;
  color: #5B21B6;
}

.pity-count {
  font-size: 26rpx;
  font-weight: 900;
  color: #7C3AED;
}

.pity-bar {
  height: 24rpx;
  background: #DDD6FE;
  border-radius: 12rpx;
  overflow: hidden;
}

.pity-fill {
  height: 100%;
  background: linear-gradient(90deg, #8B5CF6 0%, #EC4899 100%);
  border-radius: 12rpx;
  transition: width 0.5s ease;
}

.pity-hint {
  display: block;
  font-size: 22rpx;
  color: #7C3AED;
  margin-top: 8rpx;
  text-align: left;
}

/* ===== Pull Buttons ===== */
.pull-buttons {
  display: flex;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.pull-btn {
  flex: 1;
  padding: 28rpx 16rpx;
  border-radius: 24rpx;
  border: 6rpx solid var(--border-color);
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.pull-btn.single {
  background: linear-gradient(180deg, var(--primary-color) 0%, var(--primary-dark) 100%);
}

.pull-btn.ten {
  background: linear-gradient(180deg, var(--accent-purple-light) 0%, var(--accent-purple) 100%);
}

.pull-btn.disabled {
  opacity: 0.5;
}

.pull-btn-icon {
  font-size: 36rpx;
}

.pull-btn-label {
  font-size: 28rpx;
  font-weight: 900;
  color: var(--text-primary);
}

.pull-btn-cost {
  font-size: 24rpx;
  font-weight: 700;
}

.pull-btn-cost-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.pull-btn-discount {
  font-size: 20rpx;
  background: #FEF3C7;
  color: #92400E;
  padding: 2rpx 12rpx;
  border-radius: 16rpx;
  font-weight: 700;
}

/* Pull animation */
.pull-animation {
  padding: 40rpx;
  text-align: center;
}

.pull-anim-icon-img {
  width: 80rpx;
  height: 80rpx;
  display: inline-block;
  animation: spin 1s linear infinite;
}

.pull-anim-text {
  display: block;
  font-size: 32rpx;
  font-weight: 900;
  color: var(--text-primary);
  margin-top: 16rpx;
  animation: pulse 1s ease-in-out infinite;
}

/* ===== Drop Rates ===== */
.drop-rates {
  background: #F9FAFB;
  border-radius: 20rpx;
  padding: 24rpx;
  border: 4rpx solid #E5E7EB;
}

.drop-rates-title {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--text-secondary);
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.drop-rates-star {
  font-size: 28rpx;
}

.drop-rates-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.drop-rate-item {
  flex: 1;
  min-width: 40%;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 16rpx;
  background: white;
  border-radius: 12rpx;
  border: 2rpx solid #E5E7EB;
}

.drop-rate-name {
  font-size: 24rpx;
  font-weight: 700;
}

.drop-rate-pct {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--text-secondary);
}

/* ===== Empty ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx;
}

.empty-icon-circle {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: #F3F4F6;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 8rpx solid #D1D5DB;
  margin-bottom: 30rpx;
}

.empty-icon-text {
  font-size: 72rpx;
}

.empty-state-text {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-secondary);
}

.empty-state-subtext {
  font-size: 26rpx;
  color: var(--text-muted);
  margin-top: 12rpx;
}

/* ===== Results Modal ===== */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  padding: 40rpx;
}

.modal-content {
  background: white;
  border-radius: 30rpx;
  border: 6rpx solid var(--border-color);
  padding: 40rpx;
  width: 100%;
  max-width: 620rpx;
  box-shadow: 0 16rpx 0 rgba(0, 0, 0, 0.1);
}

.results-modal {
  max-height: 80vh;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 900;
  color: var(--text-primary);
}

.modal-close {
  font-size: 36rpx;
  color: var(--text-muted);
  padding: 10rpx;
}

.results-scroll {
  max-height: 600rpx;
}

.result-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx;
  background: #F9FAFB;
  border-radius: 20rpx;
  border: 4rpx solid #E5E7EB;
  margin-bottom: 16rpx;
}

.result-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid var(--border-color);
  font-size: 36rpx;
}

.result-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.result-name {
  font-size: 28rpx;
  font-weight: 900;
  color: var(--text-primary);
}

.result-rarity {
  font-size: 24rpx;
  font-weight: 700;
}

.result-pity {
  font-size: 22rpx;
  font-weight: 700;
  color: #7C3AED;
}

.modal-btn-full {
  width: 100%;
  padding: 24rpx;
  text-align: center;
  border-radius: 50rpx;
  border: 6rpx solid var(--border-color);
  font-size: 28rpx;
  font-weight: 700;
  background: linear-gradient(180deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  color: var(--text-primary);
  margin-top: 24rpx;
}

/* Loading */
.loading-container {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}
