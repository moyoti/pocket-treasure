/**app.wxss**/
/* 全局变量 */
page {
  --primary-color: #FFD93D;
  --primary-dark: #F4C430;
  --secondary-color: #6BCB77;
  --accent-color: #FF6B6B;
  --text-primary: #1A1A1A;
  --text-secondary: #4A4A4A;
  --text-muted: #6A6A6A;
  --bg-light: #FFF8E7;
  --bg-card: #FFFFFF;
  --border-color: #333333;
  
  background: linear-gradient(135deg, var(--bg-light) 0%, #FFE4B5 100%);
  min-height: 100vh;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
}

/* 卡通风格卡片 */
.cartoon-card {
  background: white;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 0 rgba(0, 0, 0, 0.1), 0 12rpx 40rpx rgba(0, 0, 0, 0.1);
  border: 6rpx solid var(--border-color);
  margin: 20rpx;
  padding: 30rpx;
}

/* 卡通风格按钮 */
.cartoon-btn {
  background: linear-gradient(180deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  color: var(--text-primary);
  font-weight: bold;
  padding: 24rpx 48rpx;
  border-radius: 50rpx;
  border: 6rpx solid var(--border-color);
  text-align: center;
  font-size: 28rpx;
}

.cartoon-btn-secondary {
  background: linear-gradient(180deg, #8FD99A 0%, var(--secondary-color) 100%);
}

.cartoon-btn-accent {
  background: linear-gradient(180deg, #FF9999 0%, var(--accent-color) 100%);
}

/* 输入框样式 */
.cartoon-input {
  background: white;
  border: 6rpx solid var(--border-color);
  border-radius: 20rpx;
  padding: 24rpx 30rpx;
  font-size: 28rpx;
}

/* 稀有度颜色 */
.rarity-common { color: #6B7280; }
.rarity-rare { color: #0EA5E9; }
.rarity-epic { color: #8B5CF6; }
.rarity-legendary { color: #F59E0B; }

.rarity-bg-common { background-color: #F3F4F6; }
.rarity-bg-rare { background-color: #DBEAFE; }
.rarity-bg-epic { background-color: #EDE9FE; }
.rarity-bg-legendary { background-color: #FEF3C7; }

/* 加载动画 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 8rpx solid var(--bg-light);
  border-top-color: var(--primary-color);
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
}

.empty-state-icon {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background-color: #F3F4F6;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
  border: 8rpx solid #E5E7EB;
}

.empty-state-text {
  font-size: 32rpx;
  color: var(--text-secondary);
  font-weight: bold;
}

.empty-state-subtext {
  font-size: 26rpx;
  color: var(--text-muted);
  margin-top: 16rpx;
}

/* 列表项 */
.list-item {
  background: white;
  padding: 30rpx;
  margin: 20rpx;
  border-radius: 20rpx;
  border: 6rpx solid var(--border-color);
  display: flex;
  align-items: center;
}

/* 徽章 */
.badge {
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  font-size: 22rpx;
  font-weight: bold;
  border: 4rpx solid;
}

.badge-common {
  background: #F3F4F6;
  color: #374151;
  border-color: #6B7280;
}

.badge-rare {
  background: #DBEAFE;
  color: #1E40AF;
  border-color: #3B82F6;
}

.badge-epic {
  background: #EDE9FE;
  color: #5B21B6;
  border-color: #8B5CF6;
}

.badge-legendary {
  background: #FEF3C7;
  color: #92400E;
  border-color: #F59E0B;
}
