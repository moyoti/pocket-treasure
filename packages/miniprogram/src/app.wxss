/**app.wxss**/
/* ==================== 全局变量 ==================== */
page {
  --primary-color: #FFD93D;
  --primary-dark: #F4C430;
  --primary-light: #FFE066;
  --secondary-color: #6BCB77;
  --secondary-light: #8FD99A;
  --secondary-dark: #5AB669;
  --accent-color: #FF6B6B;
  --accent-light: #FF9999;
  --accent-dark: #E85555;
  --accent-purple: #9B59B6;
  --accent-purple-light: #BB8FCE;
  --accent-blue: #4ECDC4;
  --accent-blue-light: #7EDDD6;
  --accent-pink: #FF8ED4;
  --accent-pink-light: #FFB8E3;
  --text-primary: #1A1A1A;
  --text-secondary: #4A4A4A;
  --text-muted: #6A6A6A;
  --text-light: #8A8A8A;
  --bg-light: #FFF8E7;
  --bg-card: #FFFFFF;
  --border-color: #333333;

  /* 稀有度颜色 */
  --rarity-common: #6B7280;
  --rarity-rare: #0EA5E9;
  --rarity-epic: #8B5CF6;
  --rarity-legendary: #F59E0B;

  background: linear-gradient(135deg, var(--bg-light) 0%, #FFE4B5 100%);
  min-height: 100vh;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
}

/* ==================== 暗黑模式变量 ==================== */
page.dark-mode {
  --text-primary: #F5F5F5;
  --text-secondary: #CCCCCC;
  --text-muted: #999999;
  --text-light: #777777;
  --bg-light: #1A1A1A;
  --bg-card: #2D2D2D;
  --border-color: #555555;
  background: linear-gradient(135deg, #1A1A1A 0%, #2D2D2D 100%);
}

page.dark-mode .cartoon-card {
  background: #2D2D2D;
  box-shadow: 0 8rpx 0 rgba(0, 0, 0, 0.3), 0 12rpx 40rpx rgba(0, 0, 0, 0.3);
}

page.dark-mode .cartoon-btn {
  background: linear-gradient(180deg, #4A4A4A 0%, #333333 100%);
  color: #F5F5F5;
  border-color: #555555;
}

page.dark-mode .cartoon-input {
  background: #333333;
  color: #F5F5F5;
  border-color: #555555;
}

page.dark-mode .setting-item {
  border-bottom-color: #404040;
}

page.dark-mode .setting-divider {
  background: #404040;
}

page.dark-mode .section {
  background: #2D2D2D;
}

page.dark-mode .section-title {
  color: #F5F5F5;
}

page.dark-mode .setting-title {
  color: #F5F5F5;
}

page.dark-mode .setting-desc {
  color: #999999;
}

page.dark-mode .toggle {
  background: #555555;
}

page.dark-mode .toggle-on {
  background: #4ADE80;
}

page.dark-mode .lang-item {
  background: #333333;
  border-color: #555555;
}

page.dark-mode .lang-item-active {
  background: #4A4A4A;
  border-color: #FFD93D;
}

page.dark-mode .lang-name {
  color: #F5F5F5;
}

/* ==================== 高对比度模式 ==================== */
page.high-contrast {
  --text-primary: #000000;
  --text-secondary: #1A1A1A;
  --text-muted: #333333;
  --bg-card: #FFFFFF;
  --border-color: #000000;
}

page.high-contrast .cartoon-card {
  border-width: 8rpx;
}

page.high-contrast .cartoon-btn {
  border-width: 8rpx;
}

page.high-contrast .setting-title {
  font-weight: 900;
}

page.high-contrast .setting-desc {
  font-weight: 600;
}

/* ==================== 减少动画模式 ==================== */
page.reduced-motion .animate-float,
page.reduced-motion .animate-pulse,
page.reduced-motion .animate-bounce-in,
page.reduced-motion .animate-slide-in-up,
page.reduced-motion .animate-slide-in-down,
page.reduced-motion .animate-slide-in-left,
page.reduced-motion .animate-slide-in-right,
page.reduced-motion .animate-wiggle,
page.reduced-motion .animate-pop,
page.reduced-motion .animate-shake,
page.reduced-motion .animate-page-enter,
page.reduced-motion .animate-chest-bounce,
page.reduced-motion .cartoon-loader,
page.reduced-motion .loading-spinner,
page.reduced-motion .rarity-glow-rare,
page.reduced-motion .rarity-glow-epic,
page.reduced-motion .rarity-glow-legendary {
  animation: none !important;
}

page.reduced-motion .rarity-glow-rare,
page.reduced-motion .rarity-glow-epic,
page.reduced-motion .rarity-glow-legendary {
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.2);
}

/* ==================== 卡通风格卡片 ==================== */
.cartoon-card {
  background: white;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 0 rgba(0, 0, 0, 0.1), 0 12rpx 40rpx rgba(0, 0, 0, 0.1);
  border: 6rpx solid var(--border-color);
  margin: 20rpx;
  padding: 30rpx;
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.cartoon-card-hover {
  transform: translateY(-4rpx);
  box-shadow: 0 16rpx 0 rgba(0, 0, 0, 0.1), 0 24rpx 60rpx rgba(0, 0, 0, 0.15);
}

.cartoon-card-active {
  transform: scale(0.98);
}

/* ==================== 卡通风格按钮 ==================== */
.cartoon-btn {
  background: linear-gradient(180deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  color: var(--text-primary);
  font-weight: bold;
  padding: 24rpx 48rpx;
  border-radius: 50rpx;
  border: 6rpx solid var(--border-color);
  text-align: center;
  font-size: 28rpx;
  letter-spacing: 2rpx;
  position: relative;
  overflow: hidden;
}

.cartoon-btn-hover {
  transform: translateY(-4rpx);
  box-shadow: 0 12rpx 0 #333, 0 16rpx 30rpx rgba(0, 0, 0, 0.2);
}

.cartoon-btn-active {
  transform: translateY(4rpx);
  box-shadow: 0 4rpx 0 #333, 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
}

.cartoon-btn-secondary {
  background: linear-gradient(180deg, var(--secondary-light) 0%, var(--secondary-color) 100%);
  color: var(--text-primary);
}

.cartoon-btn-accent {
  background: linear-gradient(180deg, var(--accent-light) 0%, var(--accent-color) 100%);
  color: var(--text-primary);
}

.cartoon-btn-purple {
  background: linear-gradient(180deg, var(--accent-purple-light) 0%, var(--accent-purple) 100%);
  color: var(--text-primary);
}

.cartoon-btn-blue {
  background: linear-gradient(180deg, var(--accent-blue-light) 0%, var(--accent-blue) 100%);
  color: var(--text-primary);
}

.cartoon-btn-pink {
  background: linear-gradient(180deg, var(--accent-pink-light) 0%, var(--accent-pink) 100%);
  color: var(--text-primary);
}

/* 按钮尺寸变体 */
.cartoon-btn-sm {
  padding: 16rpx 32rpx;
  font-size: 24rpx;
  border-width: 4rpx;
}

.cartoon-btn-lg {
  padding: 36rpx 96rpx;
  font-size: 36rpx;
}

.cartoon-btn-icon {
  padding: 24rpx;
  font-size: 40rpx;
}

/* 禁用状态 */
.cartoon-btn-disabled {
  opacity: 0.5;
  pointer-events: none;
}

/* ==================== 输入框样式 ==================== */
.cartoon-input {
  background: white;
  border: 6rpx solid var(--border-color);
  border-radius: 24rpx;
  padding: 24rpx 30rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  box-shadow: inset 0 4rpx 8rpx rgba(0, 0, 0, 0.05);
}

.cartoon-input-focus {
  border-color: var(--primary-color);
  box-shadow: inset 0 4rpx 8rpx rgba(0, 0, 0, 0.05), 0 0 0 8rpx rgba(255, 217, 61, 0.3);
}

/* ==================== 卡通标题 ==================== */
.cartoon-title {
  font-size: 64rpx;
  font-weight: 900;
  color: var(--text-primary);
  text-shadow: 4rpx 4rpx 0 var(--primary-color), 8rpx 8rpx 0 rgba(0, 0, 0, 0.1);
}

.cartoon-title-sm {
  font-size: 48rpx;
  text-shadow: 2rpx 2rpx 0 var(--primary-color), 4rpx 4rpx 0 rgba(0, 0, 0, 0.1);
}

/* ==================== 稀有度颜色 ==================== */
.rarity-common { color: #6B7280; }
.rarity-rare { color: #0EA5E9; }
.rarity-epic { color: #8B5CF6; }
.rarity-legendary { color: #F59E0B; }

.rarity-bg-common { background-color: #F3F4F6; }
.rarity-bg-rare { background-color: #DBEAFE; }
.rarity-bg-epic { background-color: #EDE9FE; }
.rarity-bg-legendary { background-color: #FEF3C7; }

/* ==================== 卡通徽章 ==================== */
.cartoon-badge {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 24rpx;
  border-radius: 50rpx;
  font-weight: 700;
  font-size: 22rpx;
  border: 4rpx solid var(--border-color);
}

.cartoon-badge-common {
  background: #E5E7EB;
  color: var(--text-primary);
}

.cartoon-badge-rare {
  background: #DBEAFE;
  color: #1E40AF;
  border-color: #3B82F6;
}

.cartoon-badge-epic {
  background: #EDE9FE;
  color: #5B21B6;
  border-color: #8B5CF6;
}

.cartoon-badge-legendary {
  background: linear-gradient(135deg, #FEF3C7 0%, #FCD34D 100%);
  color: #92400E;
  border-color: #F59E0B;
}

.cartoon-badge-success {
  background: #D1FAE5;
  color: #065F46;
  border-color: #10B981;
}

.cartoon-badge-danger {
  background: #FEE2E2;
  color: #991B1B;
  border-color: #EF4444;
}

.cartoon-badge-info {
  background: #DBEAFE;
  color: #1E40AF;
  border-color: #3B82F6;
}

.cartoon-badge-purple {
  background: #EDE9FE;
  color: #5B21B6;
  border-color: #8B5CF6;
}

/* 旧版徽章兼容 */
.badge {
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  font-size: 22rpx;
  font-weight: bold;
  border: 4rpx solid;
}

.badge-common {
  background: #F3F4F6;
  color: #374151;
  border-color: #6B7280;
}

.badge-rare {
  background: #DBEAFE;
  color: #1E40AF;
  border-color: #3B82F6;
}

.badge-epic {
  background: #EDE9FE;
  color: #5B21B6;
  border-color: #8B5CF6;
}

.badge-legendary {
  background: #FEF3C7;
  color: #92400E;
  border-color: #F59E0B;
}

/* ==================== 消息提示 / Alert ==================== */
.cartoon-alert {
  border-radius: 24rpx;
  border: 6rpx solid var(--border-color);
  padding: 24rpx 40rpx;
  font-weight: 600;
  font-size: 28rpx;
  margin: 20rpx;
}

.cartoon-alert-success {
  background: #D1FAE5;
  border-color: #10B981;
  color: #065F46;
}

.cartoon-alert-error {
  background: #FEE2E2;
  border-color: #EF4444;
  color: #991B1B;
}

.cartoon-alert-info {
  background: #DBEAFE;
  border-color: #3B82F6;
  color: #1E40AF;
}

.cartoon-alert-warning {
  background: #FEF3C7;
  border-color: #F59E0B;
  color: #92400E;
}

/* ==================== 统计卡片 ==================== */
.stat-card {
  background: linear-gradient(135deg, white 0%, #FFF8E7 100%);
  border-radius: 24rpx;
  border: 6rpx solid var(--border-color);
  padding: 30rpx;
  text-align: center;
}

.stat-number {
  font-size: 56rpx;
  font-weight: 900;
  color: #B45309;
}

.stat-label {
  font-size: 24rpx;
  color: var(--text-secondary);
  letter-spacing: 2rpx;
  font-weight: 700;
}

/* ==================== 收藏卡片 ==================== */
.collection-card {
  background: white;
  border-radius: 24rpx;
  border: 6rpx solid var(--border-color);
  overflow: hidden;
}

.collection-card-hover {
  transform: translateY(-8rpx) rotate(1deg);
  box-shadow: 0 24rpx 0 rgba(0, 0, 0, 0.1), 0 32rpx 80rpx rgba(0, 0, 0, 0.15);
}

.collection-card-image {
  background: linear-gradient(135deg, #FFF8E7 0%, #FFE4B5 100%);
  padding: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 80rpx;
}

/* ==================== 用户头像 ==================== */
.cartoon-avatar {
  border-radius: 50%;
  border: 8rpx solid var(--primary-color);
  box-shadow: 0 8rpx 0 rgba(0, 0, 0, 0.1);
}

/* ==================== 加载动画 ==================== */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 8rpx solid var(--bg-light);
  border-top-color: var(--primary-color);
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

.cartoon-loader {
  width: 100rpx;
  height: 100rpx;
  border: 10rpx solid #FFF8E7;
  border-top-color: var(--primary-color);
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

/* ==================== 骨架屏 ==================== */
.skeleton {
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s ease-in-out infinite;
  border-radius: 16rpx;
}

.skeleton-text {
  height: 28rpx;
  margin-bottom: 16rpx;
  border-radius: 8rpx;
}

.skeleton-circle {
  border-radius: 50%;
}

/* ==================== 空状态 ==================== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
}

.empty-state-icon {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background-color: #F3F4F6;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
  border: 8rpx solid #E5E7EB;
}

.empty-state-text {
  font-size: 32rpx;
  color: var(--text-secondary);
  font-weight: bold;
}

.empty-state-subtext {
  font-size: 26rpx;
  color: var(--text-muted);
  margin-top: 16rpx;
}

/* ==================== 列表项 ==================== */
.list-item {
  background: white;
  padding: 30rpx;
  margin: 20rpx;
  border-radius: 24rpx;
  border: 6rpx solid var(--border-color);
  display: flex;
  align-items: center;
}

.list-item-hover {
  background: #FFF8E7;
  transform: scale(0.98);
}

/* ==================== 分割线 ==================== */
.divider {
  height: 2rpx;
  background: #E5E7EB;
  margin: 20rpx 0;
}

/* ==================== 动画 Keyframes ==================== */
@keyframes spin {
  to { transform: rotate(360deg); }
}

@keyframes bounce-in {
  0% {
    opacity: 0;
    transform: scale(0.3);
  }
  50% {
    transform: scale(1.05);
  }
  70% {
    transform: scale(0.9);
  }
  100% {
    opacity: 1;
    transform: scale(1);
  }
}

@keyframes wiggle {
  0%, 100% { transform: rotate(-3deg); }
  50% { transform: rotate(3deg); }
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-16rpx); }
}

@keyframes slide-in-up {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes slide-in-down {
  from {
    opacity: 0;
    transform: translateY(-40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes slide-in-left {
  from {
    opacity: 0;
    transform: translateX(-40rpx);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

@keyframes slide-in-right {
  from {
    opacity: 0;
    transform: translateX(40rpx);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.7; }
}

@keyframes pop {
  0% { transform: scale(0); }
  70% { transform: scale(1.1); }
  100% { transform: scale(1); }
}

@keyframes shake {
  0%, 100% { transform: translateX(0); }
  25% { transform: translateX(-10rpx); }
  75% { transform: translateX(10rpx); }
}

@keyframes shimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}

@keyframes page-enter {
  from {
    opacity: 0;
    transform: translateY(16rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes chest-bounce {
  0%, 100% { transform: translateY(0) scale(1); }
  25% { transform: translateY(-16rpx) scale(1.02); }
  50% { transform: translateY(-8rpx) scale(1.01); }
}

@keyframes rare-glow {
  0%, 100% { box-shadow: 0 0 10rpx #3B82F6, 0 0 20rpx rgba(59, 130, 246, 0.3); }
  50% { box-shadow: 0 0 30rpx #3B82F6, 0 0 50rpx rgba(59, 130, 246, 0.5); }
}

@keyframes epic-glow {
  0%, 100% { box-shadow: 0 0 16rpx #8B5CF6, 0 0 32rpx rgba(139, 92, 246, 0.3); }
  50% { box-shadow: 0 0 40rpx #8B5CF6, 0 0 70rpx rgba(139, 92, 246, 0.5); }
}

@keyframes legendary-glow {
  0%, 100% { box-shadow: 0 0 20rpx #F59E0B, 0 0 40rpx rgba(245, 158, 11, 0.4); }
  50% { box-shadow: 0 0 50rpx #F59E0B, 0 0 80rpx rgba(245, 158, 11, 0.6); }
}

@keyframes collect-success {
  0% { transform: scale(1) rotate(0deg); opacity: 1; }
  50% { transform: scale(1.5) rotate(180deg); opacity: 0.8; }
  100% { transform: scale(0) rotate(360deg); opacity: 0; }
}

@keyframes item-spawn {
  0% { opacity: 0; transform: scale(0) translateY(40rpx); }
  50% { transform: scale(1.1) translateY(-10rpx); }
  100% { opacity: 1; transform: scale(1) translateY(0); }
}

@keyframes fade-in {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes scale-in {
  from { transform: scale(0.8); opacity: 0; }
  to { transform: scale(1); opacity: 1; }
}

/* ==================== 动画工具类 ==================== */
.animate-bounce-in {
  animation: bounce-in 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.animate-slide-in-up {
  animation: slide-in-up 300ms ease-out;
}

.animate-slide-in-down {
  animation: slide-in-down 300ms ease-out;
}

.animate-slide-in-left {
  animation: slide-in-left 300ms ease-out;
}

.animate-slide-in-right {
  animation: slide-in-right 300ms ease-out;
}

.animate-float {
  animation: float 3s ease-in-out infinite;
}

.animate-pulse {
  animation: pulse 2s ease-in-out infinite;
}

.animate-wiggle {
  animation: wiggle 0.5s ease-in-out;
}

.animate-pop {
  animation: pop 400ms cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.animate-shake {
  animation: shake 0.5s ease-in-out;
}

.animate-page-enter {
  animation: page-enter 0.3s ease-out;
}

.animate-chest-bounce {
  animation: chest-bounce 2s ease-in-out infinite;
}

.animate-fade-in {
  animation: fade-in 0.3s ease-out;
}

.animate-scale-in {
  animation: scale-in 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.animate-collect-success {
  animation: collect-success 800ms cubic-bezier(0.68, -0.55, 0.265, 1.55) forwards;
}

.animate-item-spawn {
  animation: item-spawn 500ms cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
}

/* 交错动画延迟 */
.stagger-1 { animation-delay: 50ms; }
.stagger-2 { animation-delay: 100ms; }
.stagger-3 { animation-delay: 150ms; }
.stagger-4 { animation-delay: 200ms; }
.stagger-5 { animation-delay: 250ms; }
.stagger-6 { animation-delay: 300ms; }
.stagger-7 { animation-delay: 350ms; }
.stagger-8 { animation-delay: 400ms; }

/* ==================== 稀有度发光效果 ==================== */
.rarity-glow-common {
  box-shadow: 0 4rpx 16rpx rgba(107, 114, 128, 0.3);
}

.rarity-glow-rare {
  animation: rare-glow 2s ease-in-out infinite;
}

.rarity-glow-epic {
  animation: epic-glow 2s ease-in-out infinite;
}

.rarity-glow-legendary {
  animation: legendary-glow 2s ease-in-out infinite;
}

/* ==================== 布局工具类 ==================== */
.flex-row {
  display: flex;
  flex-direction: row;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-wrap {
  flex-wrap: wrap;
}

.flex-1 {
  flex: 1;
}

.text-center {
  text-align: center;
}

.text-bold {
  font-weight: bold;
}

.text-900 {
  font-weight: 900;
}

/* ==================== 间距工具类 ==================== */
.mt-20 { margin-top: 20rpx; }
.mt-30 { margin-top: 30rpx; }
.mb-20 { margin-bottom: 20rpx; }
.mb-30 { margin-bottom: 30rpx; }
.ml-20 { margin-left: 20rpx; }
.mr-20 { margin-right: 20rpx; }
.p-20 { padding: 20rpx; }
.p-30 { padding: 30rpx; }
.px-30 { padding-left: 30rpx; padding-right: 30rpx; }
.py-20 { padding-top: 20rpx; padding-bottom: 20rpx; }

/* ==================== 文字颜色工具类 ==================== */
.text-primary { color: var(--text-primary); }
.text-secondary { color: var(--text-secondary); }
.text-muted { color: var(--text-muted); }
.text-accent { color: var(--accent-color); }
.text-success { color: var(--secondary-color); }
.text-warning { color: var(--primary-dark); }

/* ==================== 圆角工具类 ==================== */
.rounded-full { border-radius: 50%; }
.rounded-lg { border-radius: 24rpx; }
.rounded-md { border-radius: 16rpx; }
.rounded-sm { border-radius: 8rpx; }

/* ==================== 安全区域 ==================== */
.safe-area-bottom {
  padding-bottom: env(safe-area-inset-bottom, 0);
}
