{
  "name": "treasure-hunt",
  "version": "1.0.0",
  "private": true,
  "description": "寻宝记 - A location-based item collection game (纯客户端版)",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "mobile": "yarn workspace @treasure-hunt/mobile",
    "shared": "yarn workspace @treasure-hunt/shared",
    "miniprogram": "yarn workspace @treasure-hunt/miniprogram",
    "dev:mobile": "yarn workspace @treasure-hunt/mobile start",
    "lint": "yarn workspaces run lint",
    "test": "yarn workspaces run test",
    "prepare": "husky install"
  },
  "devDependencies": {
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "yarn@1.22.22"
}